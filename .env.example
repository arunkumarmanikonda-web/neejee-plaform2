# ─── NEEJEE Platform Environment Variables ───
# Copy this file to .env.local and fill in real values

# Database (use Supabase, Neon, or Railway for hosted Postgres)
DATABASE_URL="postgresql://user:password@localhost:5432/neejee?schema=public"

# Auth — generate with: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-long-random-string-in-production"

# Public URL
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Razorpay (Payments) — https://razorpay.com
# Get keys from https://dashboard.razorpay.com/app/keys
# Webhook secret from https://dashboard.razorpay.com/app/webhooks
RAZORPAY_KEY_ID="rzp_live_XXXXXXXX"
RAZORPAY_KEY_SECRET=""
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_live_XXXXXXXX"
RAZORPAY_WEBHOOK_SECRET=""

# Shiprocket (Shipping) — https://shiprocket.in
SHIPROCKET_EMAIL=""
SHIPROCKET_PASSWORD=""
SHIPROCKET_TOKEN=""

# Cloudinary (Media CDN) — https://cloudinary.com
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""

# Algolia (Search, optional) — https://algolia.com
ALGOLIA_APP_ID=""
ALGOLIA_ADMIN_KEY=""
NEXT_PUBLIC_ALGOLIA_SEARCH_KEY=""

# Klaviyo (Email Marketing) — https://klaviyo.com
KLAVIYO_API_KEY=""

# WATI (WhatsApp Business API) — https://wati.io
WATI_API_TOKEN=""
WATI_TENANT_ID=""

# Replicate (AI — Mirror & Space) — https://replicate.com
REPLICATE_API_TOKEN=""

# OpenAI (AI — Gift Concierge & Content Assistant) — https://openai.com
OPENAI_API_KEY=""

# Google Analytics
NEXT_PUBLIC_GA_ID=""

# Meta Pixel
NEXT_PUBLIC_META_PIXEL_ID=""

# Sentry (Errors)
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""

# Journal auto-curation (v23.30)
# Recipients of the weekly review email (Nidhi + all SUPER_ADMIN/ADMIN users)
NIDHI_EMAIL=
# Transactional email via Resend; without this the email is logged only.
RESEND_API_KEY=
EMAIL_FROM=NEEJEE <hello@neejee.com>
# Cron auth — must be set in Vercel env for the weekly cron to run
CRON_SECRET=
# Public base URL used in magic links (defaults to https://www.neejee.com)
NEXT_PUBLIC_APP_URL=https://www.neejee.com

# RazorpayX payouts (v23.34)
# Same Razorpay KEY_ID/KEY_SECRET drive the payments API; RazorpayX adds:
RAZORPAYX_ACCOUNT_NUMBER=
RAZORPAYX_WEBHOOK_SECRET=
RAZORPAYX_MODE=test

# ─── v23.35 Fast2SMS DLT (India) ─────────────────────────────────────────────
FAST2SMS_API_KEY=             # Fast2SMS dashboard → Dev API → API Key
FAST2SMS_SENDER_ID=NEEJEY     # 6-char DLT-approved header (NEEJEE was taken in TRAI registry)
FAST2SMS_DLT_ENTITY_ID=       # 19-digit Principal Entity ID (PEID) from DLT portal
FAST2SMS_MODE=live            # live | test
# Template IDs are managed in DB via /admin/settings/sms (not env vars)

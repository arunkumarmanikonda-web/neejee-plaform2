# ─── NEEJEE Platform Environment Variables ───
# Copy this file to .env.local and fill in real values

# Database (use Supabase, Neon, or Railway for hosted Postgres)
DATABASE_URL="postgresql://user:password@localhost:5432/neejee?schema=public"

# Auth — generate with: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-long-random-string-in-production"

# Public URL
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Razorpay (Payments) — https://razorpay.com
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
NEXT_PUBLIC_RAZORPAY_KEY_ID=""

# Shiprocket (Shipping) — https://shiprocket.in
SHIPROCKET_EMAIL=""
SHIPROCKET_PASSWORD=""
SHIPROCKET_TOKEN=""

# Cloudinary (Media CDN) — https://cloudinary.com
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""

# Algolia (Search, optional) — https://algolia.com
ALGOLIA_APP_ID=""
ALGOLIA_ADMIN_KEY=""
NEXT_PUBLIC_ALGOLIA_SEARCH_KEY=""

# Klaviyo (Email Marketing) — https://klaviyo.com
KLAVIYO_API_KEY=""

# WATI (WhatsApp Business API) — https://wati.io
WATI_API_TOKEN=""
WATI_TENANT_ID=""

# Replicate (AI — Mirror & Space) — https://replicate.com
REPLICATE_API_TOKEN=""

# OpenAI (AI — Gift Concierge & Content Assistant) — https://openai.com
OPENAI_API_KEY=""

# Google Analytics
NEXT_PUBLIC_GA_ID=""

# Meta Pixel
NEXT_PUBLIC_META_PIXEL_ID=""

# Sentry (Errors)
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""

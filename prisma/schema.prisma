// TdsCertificate ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â quarterly Form 16A statements per vendor.
// A certificate aggregates all VendorPayouts.tdsPaise for a vendor in a given quarter.
// Generated on-demand by admin; once issued, becomes the source-of-truth for that quarter.
model TdsCertificate {
  id                    String    @id @default(cuid())
  // Counterparty
  vendorId              String
  vendor                Vendor    @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  // Snapshot fields (so future vendor edits don't rewrite history)
  vendorNameSnapshot    String
  vendorPanSnapshot     String?
  vendorAddressSnapshot String?
  // Period (financial year + quarter) ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â India FY runs AprilÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Â¦ÃƒÂ¢Ã¢â€šÂ¬Ã…â€œMarch
  financialYear         String // e.g. "2025-26"
  quarter               Int // 1=Apr-Jun, 2=Jul-Sep, 3=Oct-Dec, 4=Jan-Mar
  periodStart           DateTime
  periodEnd             DateTime
  // Totals (paise)
  grossPaymentsPaise    Int       @default(0) // sum of VendorPayout.grossPaise
  tdsDeductedPaise      Int       @default(0) // sum of VendorPayout.tdsPaise
  tdsRate               Float     @default(1.0) // typical 1% for goods (194Q)
  section               String    @default("194Q") // TDS section, e.g. 194Q, 194C
  // Document trail
  certificateNumber     String?   @unique // human-readable: NJ-16A-2025-26-Q1-V0001
  pdfUrl                String? // generated PDF in storage
  issuedAt              DateTime?
  issuedByUserId        String?
  // Quarterly TRACES filing reference (manual entry by CA)
  tracesReceiptNo       String?
  tracesFilingDate      DateTime?
  // Reference: which payout IDs are covered
  coveredPayoutIds      String[]  @default([])
  // Audit
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([vendorId, financialYear, quarter])
  @@index([financialYear, quarter])
}

// GstEInvoice ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â Indian e-invoicing (mandatory above ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Â¦Ãƒâ€šÃ‚Â¡ÃƒÆ’Ã†â€™ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¹5 crore turnover).
// One row per Order. IRN (Invoice Reference Number) issued by NIC's IRP.
// We store the raw IRP response so it can be audited and re-pulled to print.
model GstEInvoice {
  id                String         @id @default(cuid())
  orderId           String         @unique
  // Issued by the IRP (NIC) ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â null until generation succeeds
  irn               String?        @unique // 64-char hex hash
  ackNo             String? // acknowledgement number
  ackDate           DateTime?
  signedQrCode      String? // base64 QR code from IRP
  signedInvoice     String? // signed invoice JWT from IRP (long)
  // Status
  status            EInvoiceStatus @default(PENDING)
  errorCode         String?
  errorMessage      String?
  // Snapshot of submitted payload for audit
  payload           Json?
  // Manual override path (when admin uploads a manually-generated IRN)
  isManual          Boolean        @default(false)
  // Cancellation (within 24 hours on the IRP)
  cancelledAt       DateTime?
  cancelReason      String?
  // Audit
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  attemptedByUserId String?

  @@index([status])
  @@index([createdAt])
}

enum EInvoiceStatus {
  PENDING // queued, not yet sent
  PROCESSING // sent to IRP, awaiting response
  ACTIVE // IRN issued
  CANCELLED // cancelled on IRP
  FAILED // IRP rejected
  EXEMPT // order below threshold or B2C, not required
}

// VendorCatalogItem ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â vendor's master rate-card.
// Distinct from Product (which is what NEEJEE sells). A catalog item is what NEEJEE
// BUYS from a specific vendor at a specific price. PurchaseOrderLine can reference
// this to auto-fill description, SKU, unit cost, GST rate.
model VendorCatalogItem {
  id                  String    @id @default(cuid())
  vendorId            String
  vendor              Vendor    @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  // Identification
  vendorSku           String // vendor's internal SKU/code
  description         String // e.g. "Banarasi silk saree ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â indigo, 6.3m"
  hsnCode             String? // HSN/SAC for tax classification
  // Optional link to a Product (when this catalog item maps to something we sell)
  productId           String?
  product             Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)
  // Pricing (paise) ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â multiple price points allowed via tieredPricing JSON
  unitCostPaise       Int // default per-unit cost
  currency            String    @default("INR")
  gstRate             Float     @default(5.0) // typical rate for this item
  // Quantity hints
  moq                 Int       @default(1) // minimum order quantity
  leadTimeDays        Int? // typical lead time in days
  // Tiered pricing (optional): [{ minQty: 10, unitCostPaise: 18000 }, ...]
  tieredPricing       Json?
  // Validity
  validFrom           DateTime  @default(now())
  validUntil          DateTime?
  active              Boolean   @default(true)
  // Reference image ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â useful when vendor uploads via portal
  imageUrl            String?
  notes               String?
  // Audit
  createdByUserId     String
  lastUpdatedByUserId String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@unique([vendorId, vendorSku])
  @@index([vendorId, active])
  @@index([productId])
}


  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @default(now()) @updatedAt

  @@index([position, active])
}

// Media asset library ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â central registry of uploaded images for reuse in CMS
model Asset {
  id          String   @id @default(cuid())
  url         String
  filename    String?
  folder      String?
  width       Int?
  height      Int?
  size        Int?
  contentType String?
  alt         String?
  caption     String?
  tags        String[] @default([])
  uploadedBy  String?
  createdAt   DateTime @default(now())

  @@index([folder])
  @@index([createdAt])
}

// ============ DISCOUNT ============
model Coupon {
  id          String             @id @default(cuid())
  code        String             @unique
  // If set, ONLY this user can redeem this coupon (e.g. welcome coupons)
  userId      String?
  // If true, every customer can redeem once (uses CouponRedemption ledger)
  perUserOnce Boolean            @default(false)
  redemptions CouponRedemption[]
  type        String // PERCENT, FLAT, FREE_SHIPPING
  value       Int
  minCart     Int                @default(0)
  maxDiscount Int?
  maxUses     Int?
  usedCount   Int                @default(0)
  validFrom   DateTime           @default(now())
  validTo     DateTime?
  active      Boolean            @default(true)

  @@index([userId])
}

// Per-user redemption ledger ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â prevents the same customer reusing a generic
// coupon (like WELCOME10 if you ever issue one) on multiple orders.
// Lightweight analytics event log ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â captures page views, ATC, purchases, etc.
model AnalyticsEvent {
  id          String   @id @default(cuid())
  sessionId   String // anonymous browser-session uuid
  userId      String? // populated if signed in
  type        String // PAGE_VIEW, PRODUCT_VIEW, ADD_TO_CART, BEGIN_CHECKOUT, PURCHASE, SEARCH, NEWSLETTER_SUBSCRIBE, ABANDON
  path        String?
  productId   String?
  value       Int? // optional value in paise (for purchase/atc)
  referrer    String?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  device      String? // mobile, desktop, tablet
  country     String?
  createdAt   DateTime @default(now())

  @@index([sessionId])
  @@index([type, createdAt])
  @@index([utmCampaign])
  @@index([productId])
}

// Abandoned cart tracking ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â server-side persistent carts for recovery emails
model AbandonedCart {
  id                   String    @id @default(cuid())
  email                String
  userId               String?
  itemsJson            String // JSON-serialized cart snapshot
  subtotal             Int
  itemCount            Int
  // Recovery state
  remindersSent        Int       @default(0)
  lastRemindedAt       DateTime?
  recoveredOrderId     String?
  recoveredAt          DateTime?
  optedOut             Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  // v26.3a ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â recovery state machine + telecaller
  phone                String?
  customerName         String?
  recoveryStage        Int       @default(0)
  nextActionAt         DateTime?
  discountCode         String?
  discountPercent      Int?
  aiCopyJson           Json?
  cartSnapshotHtml     String?
  paymentMethodPicked  String?
  lastSeenStep         String?
  razorpayOrderId      String?
  telecallerStatus     String?
  telecallerNotes      String?
  telecallerCalledAt   DateTime?
  telecallerCallbackAt DateTime?

  @@index([email])
  @@index([userId])
  @@index([recoveredOrderId])
  @@index([createdAt])
}

// Marketing email broadcast campaigns
model EmailCampaign {
  id               String    @id @default(cuid())
  name             String
  subject          String
  bodyHtml         String // rendered HTML
  bodyText         String? // plain-text version
  segment          String // ALL, CUSTOMERS, WISHLIST, VIP, LAPSED, OPTED_IN_ONLY
  status           String    @default("DRAFT") // DRAFT, SCHEDULED, SENDING, SENT, CANCELLED
  scheduledFor     DateTime?
  sentAt           DateTime?
  // Stats
  recipientCount   Int       @default(0)
  sentCount        Int       @default(0)
  openCount        Int       @default(0)
  clickCount       Int       @default(0)
  bounceCount      Int       @default(0)
  unsubscribeCount Int       @default(0)
  // Meta
  createdBy        String? // userId of admin who created it
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([status])
  @@index([sentAt])
}

model CouponRedemption {
  id         String   @id @default(cuid())
  couponId   String
  coupon     Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  userId     String
  orderId    String?
  redeemedAt DateTime @default(now())

  @@unique([couponId, userId])
  @@index([userId])
}

// ============ BADGES / SEALS ============
// Custom-managed seal/badge taxonomy. Admins can add, edit, delete badges
// and trigger AI generation of vintage wax-seal artwork for each.
model Badge {
  id          String   @id @default(cuid())
  key         String   @unique // stable slug, used in Product.badges[]
  label       String // shown on the seal
  description String // tooltip
  group       String   @default("editorial") // 'editorial' | 'craft' | 'trust'
  imageUrl    String? // AI-generated PNG seal in Supabase
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  @@index([active, sortOrder])
}

// ============ PRE-ORDERS & LIMITED DROPS (Sprint 9.3) ============

enum FulfilmentMode {
  IN_STOCK // Normal stock, ships in 3-5 days
  PREORDER // Take a deposit now, collect balance + ship when ready
  LIMITED_DROP // Numbered edition with a fixed size
}

enum DropStatus {
  DRAFT // Editing
  SCHEDULED // Set live time, awaiting countdown
  LIVE // Currently buyable
  CLOSED // Sold out or end date passed
}

// A NEEJEE Drop ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â a curated micro-collection released at a specific moment.
// Has its own /drops/[slug] landing page with countdown + founder note.
model Drop {
  id          String     @id @default(cuid())
  slug        String     @unique
  title       String
  subtitle    String?
  description String? // Long-form intro / founder note
  coverImage  String?
  startsAt    DateTime // When the drop becomes buyable
  endsAt      DateTime? // Optional close date; otherwise stays open until sold out
  productIds  String[]   @default([]) // Products included in this drop
  status      DropStatus @default(DRAFT)
  // Anticipation
  founderNote String? // Personal note from Nidhi for the drop page
  // SEO
  seoTitle    String?
  seoDesc     String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @default(now()) @updatedAt

  @@index([status, startsAt])
}

// Waitlist signup for sold-out / coming-soon pieces.
model Waitlist {
  id        String   @id @default(cuid())
  productId String
  email     String
  whatsapp  String?
  name      String?
  source    String? // pdp, drops-page, sold-out-page
  notified  Boolean  @default(false) // Has admin notified them?
  createdAt DateTime @default(now())

  @@unique([productId, email])
  @@index([productId, createdAt])
}

// Tracks the balance owed on a preorder. Created on deposit success;
// closed when admin triggers "ready to ship" and customer pays balance.
model PreorderBalance {
  id             String                @id @default(cuid())
  orderId        String // The deposit-bearing order
  productId      String
  userId         String
  depositPaise   Int // Amount already collected
  balancePaise   Int // Amount still owed
  status         PreorderBalanceStatus @default(PENDING)
  dueAt          DateTime? // Soft deadline
  paidAt         DateTime? // When customer paid the balance
  balanceOrderId String? // Razorpay/Order id of the balance payment
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @default(now()) @updatedAt

  @@index([userId, status])
  @@index([productId, status])
}

enum PreorderBalanceStatus {
  PENDING // Waiting for admin to trigger collection
  AWAITING_PAYMENT // Customer has been emailed, link active
  PAID // Customer paid balance, piece is now in fulfilment
  CANCELLED // Customer cancelled or refunded
}

// ============ OTP & SOCIAL AUTH (Sprint 9.3.2 / v23.20) ============

// Hashed OTP tokens for phone-based passwordless login.
// Codes are stored as bcrypt hashes ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â never plaintext.
model OtpToken {
  id         String    @id @default(cuid())
  phone      String // E.164 (+91XXXXXXXXXX)
  codeHash   String // bcrypt hash of the 6-digit code
  attempts   Int       @default(0)
  expiresAt  DateTime
  consumedAt DateTime?
  ipAddress  String?
  createdAt  DateTime  @default(now())

  @@index([phone, createdAt])
  @@index([expiresAt])
}


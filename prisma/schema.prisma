model AiPhotoVariant {
  id                String          @id @default(cuid())
  jobId             String
  job               AiPhotoJob      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  // The generated image
  url               String // Supabase URL (we copy from fal storage)
  // Per-variant scene metadata
  sceneType         String // 'hero' | 'lifestyle' | 'detail' | 'scale'
  sceneNote         String? // human-readable: "Draped on model ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â full body"
  // Decision: PENDING (not yet reviewed), APPROVED (added to product), REJECTED
  decision          AiPhotoDecision @default(PENDING)
  decidedAt         DateTime?
  decidedByUserId   String?
  // If APPROVED and pushed into Product.images, store the final index
  productImageIndex Int?
  // Audit
  createdAt         DateTime        @default(now())

  @@index([jobId, decision])
}

enum AiPhotoJobStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum AiPhotoDecision {
  PENDING
  APPROVED
  REJECTED
  ARCHIVED // raw source phone shot kept as backup, archived from product display
}


  @@index([status, dueOn])
  @@index([vendorId])
  @@index([purchaseOrderId])
}

enum BillStatus {
  DRAFT
  OPEN // unpaid, due in future or today
  OVERDUE // unpaid past due date
  PARTIALLY_PAID // some payments made
  PAID // fully paid
  CANCELLED
}

model BillPayment {
  id              String   @id @default(cuid())
  billId          String
  bill            Bill     @relation(fields: [billId], references: [id], onDelete: Cascade)
  // Cash flow
  amountPaise     Int
  paidOn          DateTime
  // How was it paid
  method          String? // BANK_TRANSFER, UPI, CHEQUE, CASH, RAZORPAY_PAYOUT
  reference       String? // UTR / cheque number / Razorpay payout id
  notes           String?
  // v23.38: payment receipt attachment (PDF/image)
  receiptUrl      String?
  attachments     String[] @default([]) // v23.39.4 ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â multiple supporting files
  // Optional: when a payment auto-creates an Expense row in P&L
  expenseId       String? // back-link to the Expense row
  // Audit
  createdByUserId String
  createdAt       DateTime @default(now())

  @@index([billId])
  @@index([paidOn])
}

// Recurring expense template ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â produces Bills on a schedule.
// Cron picks up rows where nextRunDate <= today and (active = true).
model RecurringExpense {
  id                 String             @id @default(cuid())
  name               String // "Vercel hosting", "Office rent ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â Mumbai"
  categoryId         String
  // Counterparty
  vendorId           String?
  vendorNameSnapshot String?
  // Default amounts (the cron creates a Bill with these ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â admin can adjust)
  amountPaise        Int
  gstPaise           Int                @default(0)
  totalPaise         Int
  // Schedule
  frequency          RecurringFrequency // MONTHLY, QUARTERLY, YEARLY, WEEKLY
  dayOfMonth         Int? // for MONTHLY/QUARTERLY/YEARLY (1-28)
  dueOffsetDays      Int                @default(15) // bill is due X days after creation
  // State
  active             Boolean            @default(true)
  lastRunDate        DateTime?
  nextRunDate        DateTime // when cron should next create a bill
  // Audit
  createdByUserId    String
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@index([active, nextRunDate])
}

enum RecurringFrequency {
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

// Anomaly snapshot ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â computed periodically (e.g. each Monday with the AI summary).
// Stores "this category spent X this week vs Y mean ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã†â€™ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â± Z stddev ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¾Ãƒâ€šÃ‚Â¢ flag if z-score > 2".
// Surfaces in the AI summary as "Heads up" lines.
model FinanceAnomalyAlert {
  id             String    @id @default(cuid())
  categoryId     String
  // Detection window
  periodStart    DateTime
  periodEnd      DateTime
  // Stats
  actualPaise    Int
  meanPaise      Int // 4-week rolling mean
  stdDevPaise    Int
  zScore         Float
  // Severity (HIGH = z > 3, MED = 2 < z < 3, LOW = 1.5 < z < 2)
  severity       String
  acknowledgedAt DateTime?
  createdAt      DateTime  @default(now())

  @@index([acknowledgedAt, createdAt])
}


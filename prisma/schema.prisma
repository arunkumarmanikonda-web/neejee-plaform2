// Every send attempt logged here. Used for audit, deduplication, debugging,
// and (later) admin dashboard showing delivery rates per channel.
model NotificationLog {
  id           String              @id @default(cuid())
  // Recipient
  userId       String? // null if sent to a bare email (no user record)
  user         User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  // What & how
  event        String // PO_SENT, ORDER_PLACED, etc.
  channel      NotificationChannel // EMAIL, WHATSAPP, SMS
  recipient    String // email address / phone number
  subject      String? // for email
  bodySnippet  String? // first ~200 chars, for log preview
  // Outcome
  status       NotificationStatus  @default(QUEUED)
  providerId   String? // Resend message id / Fast2SMS ref
  errorMessage String? // if status = FAILED or SKIPPED
  // Context
  contextType  String? // 'ORDER', 'PURCHASE_ORDER', 'VENDOR_CHANGE_REQUEST', etc.
  contextId    String? // e.g. orderId, poId
  // Timing
  attemptedAt  DateTime            @default(now())
  deliveredAt  DateTime? // when provider confirmed (or we marked SENT)
  createdAt    DateTime            @default(now())

  @@index([userId, createdAt])
  @@index([event, createdAt])
  @@index([status, createdAt])
  @@index([contextType, contextId])
}

enum NotificationChannel {
  EMAIL
  WHATSAPP
  SMS
}

enum NotificationStatus {
  QUEUED // about to attempt
  SENT // provider accepted
  DELIVERED // provider confirmed delivery (we don't always know)
  FAILED // provider rejected or network error
  SKIPPED // channel disabled by config or user opt-out

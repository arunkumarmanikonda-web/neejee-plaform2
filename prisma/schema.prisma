// A coupon is mapped to a marketing channel (= ExpenseCategory). When a coupon
// is used on an order, we attribute that order's revenue to the channel.
model MarketingChannelMap {
  id                String   @id @default(cuid())
  couponId          String   @unique
  expenseCategoryId String // points at an ExpenseCategory with isMarketingChannel=true
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// Per-month marketing budget per channel (so we can compute spend vs budget)
model MarketingBudget {
  id                String   @id @default(cuid())
  expenseCategoryId String
  periodYear        Int
  periodMonth       Int // 1-12
  budgetPaise       Int
  notes             String?
  createdByUserId   String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([expenseCategoryId, periodYear, periodMonth])
  @@index([periodYear, periodMonth])
}

// Email/campaign approval (maker-checker for marketing). Existing campaigns
// might use a different model; this extends without breaking it.
model MarketingApprovalRequest {
  id               String                  @id @default(cuid())
  resourceType     MarketingResourceType
  resourceId       String
  proposedPayload  Json // full draft state
  status           MarketingApprovalStatus @default(PENDING)
  createdByUserId  String
  reviewedByUserId String?
  reviewedAt       DateTime?
  reviewNote       String?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  @@index([status, createdAt])
  @@index([resourceType, resourceId])
}

enum MarketingResourceType {
  CAMPAIGN
  EMAIL_BROADCAST
  COUPON
  BANNER
}

enum MarketingApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  WITHDRAWN
}


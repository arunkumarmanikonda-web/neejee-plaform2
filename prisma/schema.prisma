  // are never exposed publicly.
  publicEmail         String? // e.g. hello@neejee.com
  publicPhone         String? // e.g. +91 98765 12345
  publicWhatsapp      String? // can differ from publicPhone if needed
  publicAddressLine   String? // optional display address (e.g. "Mumbai ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã†â€™ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â· Varanasi ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã†â€™ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â· Jaipur")
  socialInstagram     String? // public IG handle URL
  logoUrl             String?
  signatureUrl        String? // for invoices
  // Compliance toggles
  gstEnabled          Boolean  @default(true)
  defaultGstRate      Float    @default(5.0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

// A vendor is a supplier we purchase inventory from. Linked to a User (with
// role=VENDOR) for portal access. Same vendor can supply many products; same
// product can come from multiple vendors over time (many-to-many via
// PurchaseCost rows). VendorStatus controls whether new POs can be raised.
model Vendor {
  id                       String                @id @default(cuid())
  userId                   String?               @unique // null until vendor signs up via portal
  user                     User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)
  // Profile
  legalName                String
  displayName              String?
  contactPerson            String?
  contactEmail             String                @unique
  contactPhone             String?
  // Compliance
  gstin                    String?
  pan                      String?
  msmeNumber               String?
  // Address
  addressLine1             String?
  addressLine2             String?
  city                     String?
  state                    String?
  pincode                  String?
  country                  String                @default("India")
  // Banking (for payouts)
  bankAccountName          String?
  bankAccountNumber        String?
  bankIfsc                 String?
  bankName                 String?
  // v23.34 ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â RazorpayX cached references (avoids re-creating contact/fund_account each payout)
  rzpxContactId            String? // "cont_xxxxxxxxxxxxxx"
  rzpxFundAccountId        String? // "fa_xxxxxxxxxxxxxx"
  // Commercial
  paymentTermsDays         Int                   @default(30) // net-30 default
  defaultLeadTimeDays      Int                   @default(14)
  status                   VendorStatus          @default(PENDING)
  // v23.40.8 ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â categorise vendors by what they supply
  // ExpenseCategory group code (COGS_DIRECT, OPEX_MARKETING, OPEX_COMMUNICATION, OPEX_SHIPPING, OPEX_PEOPLE, OPEX_OFFICE, OPEX_PROFESSIONAL, OPEX_PAYMENT, OPEX_PLATFORM, OPEX_TAX_OTHER, OPEX_OTHER).
  serviceCategoryGroup     String?
  // Optional pre-selected ExpenseCategory for one-click booking against this vendor
  defaultExpenseCategoryId String?
  notes                    String?
  // Relations
  purchaseOrders           PurchaseOrder[]
  purchaseCosts            PurchaseCost[]
  magicTokens              VendorMagicToken[]
  documents                VendorDocument[]
  changeRequests           VendorChangeRequest[]
  auditLogs                VendorAuditLog[]
  teamMembers              VendorTeamMember[]
  payouts                  VendorPayout[]
  tdsCertificates          TdsCertificate[]
  catalogItems             VendorCatalogItem[]
  aiPhotoRequests          AiPhotoRequest[]
  createdAt                DateTime              @default(now())
  updatedAt                DateTime              @updatedAt

  @@index([status])
  @@index([contactEmail])
}

enum VendorStatus {
  PENDING // invited but not yet onboarded
  ACTIVE
  SUSPENDED
  ARCHIVED
}

// One-time magic links for vendor portal sign-in (also used for first-time
// password setup invites). Token is stored as bcrypt hash.
model VendorMagicToken {
  id         String    @id @default(cuid())
  vendorId   String
  vendor     Vendor    @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  tokenHash  String
  purpose    String    @default("LOGIN") // LOGIN | SET_PASSWORD
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([vendorId, createdAt])
  @@index([expiresAt])
}

// A purchase order Neejee raises to a vendor.
model PurchaseOrder {
  id                    String              @id @default(cuid())
  poNumber              String              @unique // human-readable: PO-2026-0001
  vendorId              String
  vendor                Vendor              @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  status                PurchaseOrderStatus @default(DRAFT)
  // Snapshot of vendor contact at time of PO (so changes to vendor profile don't rewrite history)
  vendorNameSnapshot    String
  vendorGstinSnapshot   String?
  vendorAddressSnapshot String?
  // Ship-to (defaults to LegalEntity address but can be overridden)
  shipToAddress         String?
  // Totals (paise, computed from lines)
  subtotalPaise         Int                 @default(0) // sum of (qty * unitCost)
  gstPaise              Int                 @default(0) // sum of GST on lines
  totalPaise            Int                 @default(0) // subtotal + gst
  currency              String              @default("INR")
  // Workflow timestamps
  sentAt                DateTime? // admin ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¾Ãƒâ€šÃ‚Â¢ vendor
  confirmedAt           DateTime? // vendor accepted
  dispatchedAt          DateTime? // vendor marked shipped
  receivedAt            DateTime? // admin marked received (GRN)
  closedAt              DateTime? // fully reconciled
  cancelledAt           DateTime?
  // Vendor-supplied references
  vendorInvoiceNumber   String?
  vendorInvoiceUrl      String? // uploaded by vendor
  trackingNumber        String?
  trackingUrl           String?
  expectedDate          DateTime?
  notes                 String?
  // Relations
  lines                 PurchaseOrderLine[]
  purchaseCosts         PurchaseCost[]
  messages              PoMessage[]
  disputes              Dispute[]
  createdById           String? // admin user who created it
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  @@index([vendorId, status])
  @@index([status, createdAt])
}

enum PurchaseOrderStatus {
  DRAFT // admin creating
  SENT // sent to vendor, awaiting confirmation
  CONFIRMED // vendor accepted
  DISPATCHED // vendor shipped
  RECEIVED // admin received goods (GRN done)
  CLOSED // fully reconciled, payment done
  CANCELLED
}

// One line per SKU / variant on the PO. `productId` may be null if buying a
// brand-new SKU not yet in catalogue ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â in that case `description` carries it.
model PurchaseOrderLine {
  id                    String        @id @default(cuid())
  purchaseOrderId       String
  purchaseOrder         PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  productId             String? // null = new SKU not yet created
  variantId             String?
  // Snapshot description (in case product is renamed later)
  description           String
  sku                   String?
  // Quantities
  orderedQty            Int // what admin ordered
  confirmedQty          Int? // what vendor confirmed
  dispatchedQty         Int? // what vendor shipped
  receivedQty           Int? // what admin actually received (GRN)
  // Costs (paise)
  unitCostPaise         Int // expected cost per unit at order time
  receivedUnitCostPaise Int? // actual cost per unit at receive time (may differ)
  gstRate               Float         @default(5.0)
  // Computed totals (line subtotal = unitCost * orderedQty, line GST = subtotal * gstRate/100)
  notes                 String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  @@index([purchaseOrderId])
  @@index([productId])
}

// Append-only ledger of actual costs paid for inventory. One row per GRN line.
// Used by Finance (v23.23) to compute weighted-average cost and gross profit.
model PurchaseCost {
  id              String         @id @default(cuid())
  productId       String
  variantId       String?
  vendorId        String
  vendor          Vendor         @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  purchaseOrderId String?
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)
  quantity        Int
  unitCostPaise   Int
  gstRate         Float          @default(5.0)
  receivedAt      DateTime       @default(now())
  notes           String?
  createdAt       DateTime       @default(now())

  @@index([productId, receivedAt])
  @@index([vendorId, receivedAt])
  @@index([purchaseOrderId])

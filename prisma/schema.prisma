// NEEJEE Database Schema
// PostgreSQL via Prisma ORM
// Run: npx prisma db push && npx prisma generate

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ USERS & AUTH ============
model User {
  id                String                  @id @default(cuid())
  email             String                  @unique
  phone             String?                 @unique
  name              String?
  passwordHash      String?
  role              Role                    @default(CUSTOMER)
  emailVerified     DateTime?
  image             String?
  addresses         Address[]
  orders            Order[]
  reviews           Review[]
  wishlist          Wishlist[]
  aiPreviews        AiPreview[]
  seller            Seller?
  vendor            Vendor? // back-ref for VENDOR role users
  customer          Customer? // v23.40.11 ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â back-ref to Customer profile if any
  vendorTeamMember  VendorTeamMember? // back-ref for VENDOR_STAFF role users
  sellerTeamMember  SellerTeamMember? // back-ref for SELLER_STAFF role users
  notificationPref  VendorNotificationPref?
  notificationLogs  NotificationLog[]
  // Marketing consents (DPDP compliant)
  marketingConsent  Boolean                 @default(false)
  smsOptIn          Boolean                 @default(false)
  whatsappOptIn     Boolean                 @default(false)
  emailOptIn        Boolean                 @default(true)
  // Optional ref to the welcome coupon
  welcomeCouponId   String?
  lastWinBackAt     DateTime? // v23.40.20 ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â last win-back email timestamp (60-day cooldown)
  // Loyalty
  loyaltyTier       String                  @default("FOUND") // FOUND, KNOWN, PERSONAL, FAMILY
  loyaltyPoints     Int                     @default(0) // current balance
  lifetimePoints    Int                     @default(0) // ever earned
  lifetimeSpend     Int                     @default(0) // sum of paid order totals (paise)
  referralCode      String?                 @unique // e.g. NIDHI-X9K2
  referredById      String? // userId of referrer (if any)
  ledgerEntries     LoyaltyLedger[]
  pointsAwarded     LoyaltyLedger[]         @relation("AwardedBy")
  referralsGiven    Referral[]              @relation("Referrer")
  referralsReceived Referral[]              @relation("Referee")
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  // v26.3b ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â phone OTP auth
  phoneVerified     Boolean   @default(false)
  phoneVerifiedAt   DateTime?
  primaryAuthMethod String?
  dateOfBirth       DateTime?
  anniversaryAt     DateTime?

  @@index([loyaltyTier])
  @@index([referralCode])
  @@index([dateOfBirth])
  @@index([anniversaryAt])
}

// Append-only points ledger ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â every earn, redeem, expire, adjust is a row.
// Balance = sum of points where expiredAt is null or in future.
model LoyaltyLedger {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String // EARN, REDEEM, EXPIRE, ADJUST, REFERRAL, WELCOME, TIER_BONUS
  points      Int // positive for credits, negative for debits
  reason      String? // human-readable: "Order NEE-12345", "Tier-up to Personal", "Manual adjustment"
  orderId     String? // link to order if applicable
  referralId  String? // link to referral event
  expiresAt   DateTime?
  awardedById String? // admin userId who made the manual adjustment
  awardedBy   User?     @relation("AwardedBy", fields: [awardedById], references: [id])
  createdAt   DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([orderId])
  @@index([expiresAt])
}

model Referral {
  id           String    @id @default(cuid())
  referrerId   String
  referrer     User      @relation("Referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  refereeId    String? // populated when referee signs up
  referee      User?     @relation("Referee", fields: [refereeId], references: [id], onDelete: SetNull)
  refereeEmail String?
  code         String // referral code used at signup or first-order
  status       String    @default("PENDING") // PENDING (signed up, no purchase), QUALIFIED (first paid), REWARDED, EXPIRED
  firstOrderId String?
  rewardedAt   DateTime?
  createdAt    DateTime  @default(now())

  @@index([referrerId])
  @@index([refereeId])
  @@index([code])
}

// Configurable loyalty settings ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â single row table
model LoyaltySettings {
  id                   String   @id @default("singleton")
  // Earn rates (paise spent per 1 point base; multipliers per tier)
  paisePerPoint        Int      @default(10000) // 100 INR = 1 point
  multiplierFound      Float    @default(1.0)
  multiplierKnown      Float    @default(1.5)
  multiplierPersonal   Float    @default(2.0)
  multiplierFamily     Float    @default(3.0)
  // Redemption (paise per 1 point)
  redemptionValue      Int      @default(100) // 1 point = ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Â¦Ãƒâ€šÃ‚Â¡ÃƒÆ’Ã†â€™ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¹1 off
  minRedemption        Int      @default(100) // minimum 100 points to redeem
  maxRedemptionPct     Int      @default(50) // max 50% of order can be paid with points
  // Tier thresholds (lifetime paid spend in paise)
  thresholdKnown       Int      @default(2500000) // ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Â¦Ãƒâ€šÃ‚Â¡ÃƒÆ’Ã†â€™ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¹25,000
  thresholdPersonal    Int      @default(7500000) // ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Â¦Ãƒâ€šÃ‚Â¡ÃƒÆ’Ã†â€™ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¹75,000
  thresholdFamily      Int      @default(20000000) // ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Â¦Ãƒâ€šÃ‚Â¡ÃƒÆ’Ã†â€™ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¹2,00,000
  // Referral
  referralRewardPoints Int      @default(500)
  refereeDiscountPct   Int      @default(10)
  refereeMinOrder      Int      @default(250000) // ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Â¦Ãƒâ€šÃ‚Â¡ÃƒÆ’Ã†â€™ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¹2,500
  // Expiry
  pointsExpireMonths   Int      @default(12)
  familyNeverExpire    Boolean  @default(true)
  updatedAt            DateTime @default(now()) @updatedAt
}

enum Role {
  CUSTOMER
  SELLER
  SELLER_STAFF
  ADMIN
  SUPER_ADMIN
  QC_TEAM
  CONTENT_EDITOR
  VENDOR
  VENDOR_STAFF
  FINANCE
  FINANCE_OPERATOR
  MARKETING_OPERATOR
  MARKETING_MANAGER
  TELECALLER
}

model Address {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  phone     String
  line1     String
  line2     String?
  city      String
  state     String
  pincode   String
  country   String  @default("IN")
  isDefault Boolean @default(false)
  orders    Order[]
}

// ============ CATALOG ============
model Category {
  id          String     @id @default(cuid())
  slug        String     @unique
  name        String
  parentId    String?
  parent      Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryHierarchy")
  image       String?
  description String?
  seoTitle    String?
  seoDesc     String?
  products    Product[]
  order       Int        @default(0)
  // v23.33 ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â admin can toggle visibility and mark featured
  active      Boolean    @default(true)
  featured    Boolean    @default(false)
  // v23.40.26.0 ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â Sprint 26 taxonomy fields
  level       Int        @default(1) // 1=main, 2=sub, 3=sub-sub
  path        String? // denormalised slug path: 'home/lighting-decorative' for fast lookups & breadcrumbs
  hidden      Boolean    @default(false) // admin toggle (independent of active ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â active=archived, hidden=temporarily off-nav)
  aiGenerated Boolean    @default(false) // marks AI-seeded vs hand-curated entries
  gender      String? // 'men' | 'women' | 'unisex' ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â facet for Accessories
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @default(now()) @updatedAt

  @@index([active, order])
  @@index([featured])
  @@index([level, parentId])
  @@index([path])
  @@index([hidden])
}

// v23.40.26.0 ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â Slug redirects for renamed/merged categories.
// Example: /categories/jewellery ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¾Ãƒâ€šÃ‚Â¢ /categories/accessories/jewellery
model CategoryRedirect {
  id        String    @id @default(cuid())
  fromSlug  String    @unique // old slug or full path (e.g. 'jewellery' or 'old/path/here')
  toSlug    String // new path ('accessories/jewellery')
  permanent Boolean   @default(true) // 301 vs 302
  hitCount  Int       @default(0) // analytics: how often this redirect fires
  lastHitAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt

  @@index([fromSlug])
}

model Product {
  id                   String                      @id @default(cuid())
  slug                 String                      @unique
  sku                  String                      @unique
  name                 String
  shortName            String?
  poeticLine           String?
  description          String?
  // Brand & origin
  sellerId             String?
  seller               Seller?                     @relation(fields: [sellerId], references: [id])
  // Ownership: OWNED = Neejee bought inventory; MARKETPLACE = seller-listed (commission model)
  ownershipModel       ProductOwnership            @default(OWNED)
  // Set true by admin to hide from PLP/PDP. Existing orders still fulfill.
  takedownAt           DateTime?
  takedownReason       String?
  takedownByUserId     String?
  inventorySubmissions SellerInventorySubmission[]
  vendorCatalogItems   VendorCatalogItem[]
  aiPhotoJobs          AiPhotoJob[]
  aiPhotoRequests      AiPhotoRequest[]
  craft                String? // Banarasi, Chanderi, etc.
  region               String? // Varanasi, Kanchipuram, etc.
  state                String?
  cluster              String?
  artisanName          String?
  // Classification
  categoryId           String
  category             Category                    @relation(fields: [categoryId], references: [id])
  material             String?
  technique            String?
  occasion             String?
  // Pricing
  mrp                  Int // in paise (ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Â¦Ãƒâ€šÃ‚Â¡ÃƒÆ’Ã†â€™ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¹1 = 100 paise)
  sellingPrice         Int
  salePrice            Int?
  saleStartsAt         DateTime?
  saleEndsAt           DateTime?
  gstRate              Float                       @default(5.0)
  hsnCode              String?
  // Variants
  variants             Variant[]
  // Media
  images               String[]                    @default([])
  video                String?
  // Content
  story                String?
  craftNote            String?
  careInstructions     String?
  sustainabilityNote   String?

  // Phase 1 ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â read-model / catalogue curation
  catalogueFeatured          Boolean @default(false)
  catalogueBestseller        Boolean @default(false)
  catalogueEditorial         Boolean @default(false)
  cataloguePinHero           Boolean @default(false)
  catalogueExclude           Boolean @default(false)
  cataloguePreferredImage    String?
  catalogueAudienceTag       String?
  catalogueCtaMode           String? // SHOP_NOW | ENQUIRE | WHATSAPP | REQUEST_CALLBACK | VIEW_COLLECTION
  catalogueStoryBlock        String?
  catalogueImageApproved     Boolean @default(false)
  catalogueImageQualityScore Int?
  catalogueStockVisibility   String  @default("IN_STOCK_ONLY") // IN_STOCK_ONLY | SHOW_ALL | HIDE_STOCK

  // Status
  status          ProductStatus  @default(DRAFT)
  badges          String[]       @default([])
  // SEO
  seoTitle        String?
  seoDesc         String?
  // AI eligibility
  aiTryOnEligible Boolean        @default(false) // NEEJEE Mirror ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â clothing virtual try-on
  aiRoomEligible  Boolean        @default(false) // NEEJEE Space ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â place in your room
  arTryOnEligible Boolean        @default(false) // AR Try-On ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â jewellery (earrings, necklaces, bangles, rings)
  codEligible     Boolean        @default(true) // Cash-on-delivery available
  returnEligible  Boolean        @default(true)
  returnPolicy    String? // Per-product return note (overrides global)
  // Fulfilment mode ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â Sprint 9.3 (Pre-orders & Limited Drops)
  fulfilmentMode  FulfilmentMode @default(IN_STOCK)
  depositPercent  Int? // 1-100; only used when fulfilmentMode = PREORDER
  releaseDate     DateTime? // Estimated ship date for preorder
  editionSize     Int? // e.g. 24 for "Edition of 24" ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â only LIMITED_DROP
  editionSold     Int            @default(0) // counter; piece is sold-out when sold >= size
  // Relations
  reviews         Review[]
  wishlist        Wishlist[]
  cartItems       CartItem[]
  orderItems      OrderItem[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([categoryId])
  @@index([sellerId])
  @@index([status])
  @@index([catalogueExclude])
  @@index([cataloguePinHero])
  @@index([catalogueFeatured])
  @@index([catalogueBestseller])
  @@index([catalogueEditorial])
  @@index([catalogueAudienceTag])
}


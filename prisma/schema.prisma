  employee        Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  month           Int // 1-12
  year            Int
  daysWorked      Int
  leavesPaid      Int      @default(0)
  leavesUnpaid    Int      @default(0)
  overtimeHours   Float    @default(0)
  notes           String?
  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([employeeId, month, year])
  @@index([month, year])
}

// One-time earnings/deductions outside the standard structure.
model EmployeeAdjustment {
  id                 String   @id @default(cuid())
  employeeId         String
  employee           Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  // Apply in this specific payroll period
  forMonth           Int // 1-12
  forYear            Int
  // Kind & amount
  kind               String // 'INCENTIVE' | 'BONUS' | 'REIMBURSEMENT' | 'ADVANCE' | 'LOAN_EMI' | 'FINE' | 'OTHER_EARNING' | 'OTHER_DEDUCTION'
  amountPaise        Int // positive number; sign determined by kind
  description        String
  // Applied status
  appliedToPayslipId String? // set once consumed in a payroll run
  // Audit
  createdByUserId    String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([employeeId, forYear, forMonth])
  @@index([appliedToPayslipId])
}

// Toggleable payroll configuration ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â typically one row.
model PayrollConfig {
  id                   String   @id @default("singleton")

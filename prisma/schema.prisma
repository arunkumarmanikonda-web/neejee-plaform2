// v23.40.2 ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â Payments recorded against an Expense.
// A booked expense may be paid in multiple installments; each ExpensePayment
// becomes a credit in the counterparty (vendor / payee) ledger.
model ExpensePayment {
  id              String   @id @default(cuid())
  expenseId       String
  expense         Expense  @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  amountPaise     Int
  paidOn          DateTime
  method          String? // BANK_TRANSFER | UPI | CHEQUE | CASH | CARD | RAZORPAY_PAYOUT | NEFT | RTGS
  reference       String? // UTR / cheque number / Razorpay payout id
  notes           String?
  // Supporting documents (PDF / image of receipt, bank confirmation, etc.)
  receiptUrl      String?
  attachments     String[] @default([])
  // Audit
  createdByUserId String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([expenseId])
  @@index([paidOn])
}

// ============================================================================
// v23.40.5 ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â REVENUE & SALES LEDGER LAYER
// ============================================================================
// Comprehensive revenue accounting. Every sale (website order, POS, bulk, or
// marketplace commission) produces one SalesInvoice and a fan-out of
// RevenueEntry rows broken up into Product Revenue / GST / Shipping / Discount /
// COGS / Commission / Seller Payable.
//
// Idempotency: sourceHash guarantees that posting the same Order/Invoice twice
// will not double-book any ledger entries.
// ============================================================================

// Single line in the unified revenue ledger.
// Each posting is "signed" ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â positive credits, negative debits ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â so a running
// sum gives the net position of any account.
model RevenueEntry {
  id             String    @id @default(cuid())
  // Source linkage
  orderId        String?
  orderItemId    String?
  invoiceId      String? // SalesInvoice.id
  invoiceLineId  String? // SalesInvoiceLine.id
  // Classification
  type           String // 'PRODUCT_REVENUE' | 'SHIPPING_REVENUE' | 'GST_CGST_OUTPUT' | 'GST_SGST_OUTPUT' | 'GST_IGST_OUTPUT' | 'DISCOUNT' | 'COGS' | 'COMMISSION_INCOME' | 'SELLER_PAYABLE' | 'PAYMENT_GATEWAY_FEE' | 'COD_HANDLING_FEE' | 'REFUND_REVERSAL'
  channel        String // 'WEBSITE' | 'POS' | 'BULK' | 'MARKETPLACE' | 'WHATSAPP'
  saleType       String // 'DIRECT' (Neejee-owned product) | 'MARKETPLACE' (third-party seller)
  // Money (paise, signed)
  amountPaise    Int // positive = credit/income, negative = debit/expense
  // GST detail (only used for GST_* types and ref on product lines)
  gstRatePercent Float?
  cgstPaise      Int       @default(0)
  sgstPaise      Int       @default(0)
  igstPaise      Int       @default(0)
  hsnSac         String?
  // Counterparty / product context
  customerUserId String? // for AR ledger
  customerName   String? // snapshot
  sellerId       String? // for marketplace settlement
  productId      String?
  variantId      String?
  // Realization status ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â accrual vs cash
  status         String    @default("ACCRUED") // 'ACCRUED' | 'REALIZED' | 'REVERSED'
  realizedOn     DateTime?
  paymentRef     String? // gateway / UTR ref
  // Period
  txnDate        DateTime
  monthBucket    String // 'YYYY-MM' for fast aggregation
  // Audit / idempotency
  sourceHash     String    @unique // deterministic key to prevent re-posting
  postedByUserId String?
  notes          String?
  reversedById   String? // points to the entry that reverses this one
  createdAt      DateTime  @default(now())

  @@index([orderId])
  @@index([invoiceId])
  @@index([type, monthBucket])
  @@index([channel, monthBucket])
  @@index([saleType, monthBucket])
  @@index([sellerId, monthBucket])
  @@index([customerUserId])
  @@index([status, txnDate])
}

// Customer-facing sales invoice (B2C, B2B, POS, BULK, COMMISSION).
// Either auto-generated from an Order or manually created via the POS form.
model SalesInvoice {
  id                String                @id @default(cuid())
  invoiceNumber     String                @unique // INV/2606/0001 or COM/2606/0001 ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â sequential per FY
  invoiceType       String // 'B2C' | 'B2B' | 'POS' | 'BULK' | 'COMMISSION'
  saleChannel       String // 'WEBSITE' | 'POS' | 'BULK' | 'WHATSAPP' | 'MARKETPLACE_COMMISSION'
  saleType          String                @default("DIRECT") // 'DIRECT' | 'MARKETPLACE' (snapshot from products)
  // Buyer details
  customerId        String? // v23.40.11 ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â link to Customer profile
  customerUserId    String?
  customerName      String
  customerEmail     String?
  customerPhone     String?
  customerGstin     String?
  billingAddress    String?
  shippingAddress   String?
  // For commission invoices billed TO a seller
  sellerId          String?
  // For website-originated invoices
  orderId           String?               @unique // one invoice per order
  // Dates
  issuedOn          DateTime              @default(now())
  dueOn             DateTime?
  placeOfSupply     String? // state code for IGST decision
  // Totals (paise)
  subtotalPaise     Int                   @default(0) // sum of line subtotals (pre-tax, post-discount)
  discountPaise     Int                   @default(0)
  taxableValuePaise Int                   @default(0)
  cgstPaise         Int                   @default(0)
  sgstPaise         Int                   @default(0)
  igstPaise         Int                   @default(0)
  shippingPaise     Int                   @default(0)
  shippingTaxPaise  Int                   @default(0)
  roundOffPaise     Int                   @default(0)
  totalPaise        Int                   @default(0)
  paidPaise         Int                   @default(0)
  paymentStatus     String                @default("UNPAID") // 'UNPAID' | 'PARTIALLY_PAID' | 'PAID' | 'CANCELLED' | 'VOID'
  // Lines + payments
  lines             SalesInvoiceLine[]
  payments          SalesInvoicePayment[]
  // Linkage to revenue postings
  posted            Boolean               @default(false)
  postedAt          DateTime?
  // Documents
  pdfUrl            String?
  attachments       String[]              @default([])
  notes             String?
  // Audit
  createdByUserId   String
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  @@index([invoiceType, issuedOn])
  @@index([sellerId])
  @@index([customerUserId])
  @@index([paymentStatus, dueOn])
}

model SalesInvoiceLine {
  id                        String       @id @default(cuid())
  invoiceId                 String
  invoice                   SalesInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  productId                 String?
  variantId                 String?
  sku                       String?
  description               String // product / service name snapshot
  hsnSac                    String?
  quantity                  Float        @default(1)
  unitPricePaise            Int // before discount, before tax
  discountPaise             Int          @default(0)
  taxableValuePaise         Int // (qty * unitPrice) - discount
  gstRatePercent            Float        @default(0)
  cgstPaise                 Int          @default(0)
  sgstPaise                 Int          @default(0)
  igstPaise                 Int          @default(0)
  totalPaise                Int // taxableValue + taxes
  // Cost & margin tracking (only for product lines)
  unitCostPaise             Int? // landing cost at time of sale
  cogsPaise                 Int? // qty * unitCost
  saleType                  String       @default("DIRECT") // 'DIRECT' | 'MARKETPLACE'
  sellerId                  String?
  // Commission line specifics (used when invoiceType=COMMISSION)
  commissionRatePercent     Float?
  commissionBaseAmountPaise Int?

  @@index([invoiceId])
  @@index([productId])
  @@index([sellerId])
}

model SalesInvoicePayment {
  id              String       @id @default(cuid())
  invoiceId       String
  invoice         SalesInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amountPaise     Int
  paidOn          DateTime
  method          String? // CASH | UPI | CARD | BANK_TRANSFER | RAZORPAY | NEFT | RTGS | CHEQUE
  reference       String? // UTR / gateway ID / cheque #
  notes           String?
  receiptUrl      String?
  attachments     String[]     @default([])
  createdByUserId String
  createdAt       DateTime     @default(now())

  @@index([invoiceId])
  @@index([paidOn])
}

// Period lock ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â once a month is closed, no new postings or edits to that month.
// Useful for clean financial close, GST filing, statutory audits.
model PeriodLock {
  id             String   @id @default(cuid())
  monthBucket    String   @unique // 'YYYY-MM'
  lockedByUserId String
  lockedAt       DateTime @default(now())
  notes          String?
}

// Sequential invoice number counter (per financial year).
// Pattern: "INV/2606/0001" ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â INV=type, 2606=YYMM, 0001=sequence.
model InvoiceNumberCounter {
  id        String @id @default(cuid())
  prefix    String // 'INV' | 'COM' | 'POS' | 'BLK'
  yearMonth String // 'YYMM' (e.g. '2606')
  lastValue Int    @default(0)

  @@unique([prefix, yearMonth])
}

// ============================================================================
// v23.40.11 ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â Customer Profile + AR Ledger
// ============================================================================
// Walk-in, B2B, anonymous COD, repeat POS, recurring online buyers ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â all unified.
// Distinct from the User model: User is a logged-in website account; Customer is
// any party we invoice (including anonymous offline buyers with phone/email only).
//
// When a SalesInvoice is created with a customerId set, every revenue posting +
// payment + refund flows into the customer ledger, mirroring the vendor ledger.

model Customer {
  id               String   @id @default(cuid())
  // Display
  displayName      String // "Acme Pvt Ltd" or "Ravi Kumar (Walk-in)"
  legalName        String? // for B2B GST invoices
  // Contact
  primaryEmail     String?  @unique
  primaryPhone     String?  @unique
  // Compliance (B2B)
  gstin            String?
  pan              String?
  placeOfSupply    String? // state code (for IGST/CGST decision)
  // Billing
  billingAddress   String?
  shippingAddress  String?
  // Classification
  customerType     String   @default("INDIVIDUAL") // INDIVIDUAL | B2B | WHOLESALE | INTERNAL
  channel          String   @default("WEBSITE") // WEBSITE | POS | BULK | WHATSAPP | REFERRAL
  // Link to User account if they later sign up online
  userId           String?  @unique
  user             User?    @relation(fields: [userId], references: [id])
  // Credit policy (used by AR aging)
  creditLimitPaise Int      @default(0) // 0 = no credit; sells only on advance
  creditDays       Int      @default(0) // payment terms (e.g. 30 = net 30)
  // Status
  status           String   @default("ACTIVE") // ACTIVE | INACTIVE | BLOCKED
  // Notes & audit
  notes            String?
  source           String   @default("MANUAL") // MANUAL | AUTO_POS | AUTO_ORDER | IMPORT
  createdByUserId  String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([displayName])
  @@index([customerType])
  @@index([status])
  @@index([gstin])
}

// v26.3a ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â Recovery settings singleton (id = 'default')
model RecoverySettings {
  id                       String   @id @default("default")
  cadenceHours             Json     @default("{\"stage1\":1,\"stage2\":24,\"stage3\":72,\"stage4\":168}")
  discountPercents         Json     @default("{\"stage2\":10,\"stage3\":15}")
  aiEnabled                Boolean  @default(true)
  telecallerHandoffEnabled Boolean  @default(true)
  abandonGraceMinutes      Int      @default(30)
  updatedAt                DateTime @default(now()) @updatedAt

  // v26.3b ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â per-stage channel toggles
  channelMatrix Json @default("{\"stage1\":{\"email\":true,\"sms\":false,\"whatsapp\":false},\"stage2\":{\"email\":true,\"sms\":false,\"whatsapp\":true},\"stage3\":{\"email\":true,\"sms\":false,\"whatsapp\":true},\"stage4\":{\"email\":true,\"sms\":true,\"whatsapp\":false}}")
}

// v26.3b ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â Notification dispatch audit log
model NotificationDispatch {
  id                   String    @id @default(cuid())
  channel              String
  event                String
  templateName         String
  recipient            String
  userId               String?
  orderId              String?
  cartId               String?
  providerRequestId    String?
  status               String    @default("queued")
  errorMessage         String?
  attempt              Int       @default(1)
  maxAttempts          Int       @default(3)
  nextRetryAt          DateTime?
  payloadJson          Json?
  providerResponseJson Json?
  sentAt               DateTime?
  deliveredAt          DateTime?
  readAt               DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([status, nextRetryAt])
  @@index([channel, event])
  @@index([userId])
  @@index([orderId])
  @@index([cartId])
  @@index([providerRequestId])
}

// v26.3b ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â Notification template registry
model NotificationTemplate {
  id                 String    @id @default(cuid())
  key                String    @unique
  channel            String
  providerTemplateId String?
  providerName       String
  displayName        String
  bodyPreview        String?
  variableCount      Int       @default(0)
  approvalStatus     String    @default("pending")
  enabled            Boolean   @default(true)
  lastUsedAt         DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

// v26.3b ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â A/B testing framework
model AbTest {
  id          String         @id @default(cuid())
  key         String         @unique
  displayName String
  enabled     Boolean        @default(false)
  startedAt   DateTime?
  endedAt     DateTime?
  createdAt   DateTime       @default(now())
  variants    AbVariant[]
  assignments AbAssignment[]
}

model AbVariant {
  id          String         @id @default(cuid())
  abTestId    String
  abTest      AbTest         @relation(fields: [abTestId], references: [id], onDelete: Cascade)
  key         String
  displayName String
  payloadJson Json
  weight      Int            @default(50)
  createdAt   DateTime       @default(now())
  assignments AbAssignment[]

  @@unique([abTestId, key])
}

model AbAssignment {
  id                   String    @id @default(cuid())
  abTestId             String
  abTest               AbTest    @relation(fields: [abTestId], references: [id], onDelete: Cascade)
  variantId            String
  variant              AbVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  subjectKey           String
  subjectType          String
  exposedAt            DateTime  @default(now())
  convertedAt          DateTime?
  conversionValuePaise Int?

  @@unique([abTestId, subjectKey])
  @@index([subjectKey, subjectType])
}

model Fast2SmsProviderTemplate {
  id         String   @id @default(cuid())
  messageId  String   @unique
  entityId   String?
  entityName String?
  senderId   String?
  status     String?
  category   String?
  language   String?
  body       String   @db.Text
  sourcePage String?
  rawMeta    Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([status])
  @@index([senderId])
  @@index([category])
}

enum AgreementStatus {
  DRAFT
  INTERNAL_REVIEW
  SELLER_REVIEW
  READY_TO_LOCK
  LOCKED
  SENT_FOR_SIGNATURE
  SELLER_SIGNED
  COMPANY_SIGNED
  CLOSED
  VOID
}

enum AgreementObservationStatus {
  OPEN
  RESOLVED
  REJECTED
  WITHDRAWN
}

enum AgreementActorType {
  ADMIN
  LEGAL
  SELLER
  SYSTEM
}

enum AgreementSignatureKind {
  COMPANY
  SELLER
}

model LegalSignatory {
  id              String    @id @default(cuid())
  name            String
  title           String
  email           String?
  phone           String?
  signatureUrl    String?
  isDefault       Boolean   @default(false)
  isActive        Boolean   @default(true)
  effectiveFrom   DateTime?
  effectiveTo     DateTime?
  createdByUserId String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  agreements SellerAgreement[]
}

model SellerAgreement {
  id       String @id @default(cuid())
  sellerId String @unique
  seller   Seller @relation(fields: [sellerId], references: [id])

  status           AgreementStatus @default(DRAFT)
  currentVersionNo Int             @default(1)

  companySignatoryId String?
  companySignatory   LegalSignatory? @relation(fields: [companySignatoryId], references: [id])

  lockedAt         DateTime?
  lockedByUserId   String?
  reopenedAt       DateTime?
  reopenedByUserId String?

  sellerSignedAt  DateTime?
  companySignedAt DateTime?

  sellerExecutionMode String?
  sellerExecutionRef  String?
  sellerOtpHash       String?
  sellerOtpExpiresAt  DateTime?

  currentDocumentJson Json
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  versions     SellerAgreementVersion[]
  observations SellerAgreementObservation[]
  assignments  SellerAgreementAssignment[]
  events       SellerAgreementEvent[]
  signatures   SellerAgreementSignature[]
}

model SellerAgreementVersion {
  id          String          @id @default(cuid())
  agreementId String
  agreement   SellerAgreement @relation(fields: [agreementId], references: [id])

  versionNo       Int
  documentJson    Json
  changeSummary   String?
  createdByUserId String?
  createdAt       DateTime @default(now())

  @@unique([agreementId, versionNo])
}

model SellerAgreementObservation {
  id          String          @id @default(cuid())
  agreementId String
  agreement   SellerAgreement @relation(fields: [agreementId], references: [id])

  versionNo     Int
  clauseId      String
  paragraphKey  String
  paragraphText String?

  sellerComment String
  sellerUserId  String?
  adminResponse String?
  status        AgreementObservationStatus @default(OPEN)

  resolvedByUserId String?
  resolvedAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([agreementId, clauseId, paragraphKey])
}

model SellerAgreementAssignment {
  id          String          @id @default(cuid())
  agreementId String
  agreement   SellerAgreement @relation(fields: [agreementId], references: [id])

  userId       String
  roleSnapshot Role
  canReview    Boolean @default(true)
  canComment   Boolean @default(true)
  canSign      Boolean @default(false)
  canClose     Boolean @default(false)

  assignedByUserId String?
  createdAt        DateTime @default(now())

  @@unique([agreementId, userId])
}

model SellerAgreementEvent {
  id          String          @id @default(cuid())
  agreementId String
  agreement   SellerAgreement @relation(fields: [agreementId], references: [id])

  actorUserId String?
  actorType   AgreementActorType
  action      String
  details     Json?
  createdAt   DateTime           @default(now())

  @@index([agreementId, createdAt])
}

model SellerAgreementSignature {
  id          String          @id @default(cuid())
  agreementId String
  agreement   SellerAgreement @relation(fields: [agreementId], references: [id])

  kind         AgreementSignatureKind
  signerName   String
  signerTitle  String?
  signerUserId String?
  signatureUrl String?
  authMode     String?
  authRef      String?
  signedAt     DateTime?
  auditData    Json?

  createdAt DateTime @default(now())
}

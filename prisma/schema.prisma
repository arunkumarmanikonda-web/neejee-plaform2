model SellerDocument {
  id               String               @id @default(cuid())
  sellerId         String
  seller           Seller               @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  docType          SellerDocType
  title            String?
  fileName         String
  fileUrl          String
  fileSize         Int
  mimeType         String
  status           SellerDocStatus      @default(SUBMITTED)
  uploadedByUserId String
  uploadedOnBehalf Boolean              @default(false)
  reviewedByUserId String?
  reviewedAt       DateTime?
  reviewNote       String?
  changeRequestId  String?
  changeRequest    SellerChangeRequest? @relation(fields: [changeRequestId], references: [id], onDelete: SetNull)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@index([sellerId, docType])
  @@index([status])
}

enum SellerDocType {
  PAN_CARD
  GST_CERTIFICATE
  MSME_CERTIFICATE
  CANCELLED_CHEQUE
  BANK_STATEMENT
  ADDRESS_PROOF
  AADHAAR_SIGNATORY
  SIGNATORY_PHOTO
  SELLER_AGREEMENT
  PRODUCT_CATALOG
  CERTIFICATION // GI, organic, hand-loom etc.
  OTHER
}

enum SellerDocStatus {
  SUBMITTED
  APPROVED
  REJECTED
  SUPERSEDED
}

model SellerChangeRequest {
  id                String                    @id @default(cuid())
  sellerId          String
  seller            Seller                    @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  fieldChanges      Json
  reason            String?
  status            SellerChangeRequestStatus @default(PENDING)
  requestedByUserId String
  requestedOnBehalf Boolean                   @default(false)
  reviewedByUserId  String?
  reviewedAt        DateTime?
  reviewNote        String?
  appliedAt         DateTime?
  cancelledAt       DateTime?
  supportingDocs    SellerDocument[]
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt

  @@index([sellerId, status])
}

enum SellerChangeRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model SellerAuditLog {
  id          String   @id @default(cuid())
  sellerId    String
  seller      Seller   @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  actorUserId String?
  actorRole   String?
  action      String
  details     Json?
  ipAddress   String?
  createdAt   DateTime @default(now())

  @@index([sellerId, createdAt])
}

model SellerMagicToken {
  id         String    @id @default(cuid())
  sellerId   String
  seller     Seller    @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  tokenHash  String
  purpose    String    @default("LOGIN")
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([sellerId, createdAt])
}

model SellerTeamMember {
  id              String                @id @default(cuid())
  sellerId        String
  seller          Seller                @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  userId          String                @unique
  user            User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName     String?
  email           String
  accessLevel     SellerTeamAccessLevel @default(FULL)
  status          SellerTeamStatus      @default(INVITED)
  invitedByUserId String?
  invitedAt       DateTime              @default(now())
  acceptedAt      DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@index([sellerId])
  @@index([email])
}

enum SellerTeamAccessLevel {
  FULL
  INVENTORY_ONLY // can upload SKUs, can't change bank/payouts
  FINANCE_ONLY // sees payouts, no inventory edits
}

enum SellerTeamStatus {
  INVITED
  ACTIVE
  SUSPENDED
  REMOVED
}

// Seller inventory submission ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â bulk Excel OR per-product webform.
// Lands in admin draft queue. Admin polishes, then publishes (creates Product).
model SellerInventorySubmission {
  id               String                    @id @default(cuid())
  sellerId         String
  seller           Seller                    @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  submissionType   InventorySubmissionType
  // For NEW submissions: full proposed data
  proposedData     Json // {name, sku, mrp, sellingPrice, description, images, variants...}
  // For EDIT submissions: which product is being changed
  productId        String?
  product          Product?                  @relation(fields: [productId], references: [id], onDelete: SetNull)
  // Workflow
  status           InventorySubmissionStatus @default(SUBMITTED)
  createdByUserId  String
  reviewedByUserId String?
  reviewedAt       DateTime?
  reviewNote       String?
  publishedAt      DateTime?
  // For bulk: link to the original Excel file
  sourceFileUrl    String?
  sourceFileName   String?
  // Audit
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt

  @@index([sellerId, status])
  @@index([status, createdAt])
}

enum InventorySubmissionType {
  NEW_PRODUCT
  EDIT_EXISTING
  PRICE_UPDATE
  INVENTORY_UPDATE
  TAKEDOWN_REQUEST
}

enum InventorySubmissionStatus {
  SUBMITTED // seller created, in admin queue
  UNDER_REVIEW // admin actively working on it
  NEEDS_INFO // admin asked seller for clarification
  APPROVED // approved, awaiting publish
  PUBLISHED // live on storefront
  REJECTED
  WITHDRAWN // seller cancelled
}

// Commission overrides per category & per product (in addition to seller.commissionPercent)
model SellerCategoryCommission {
  id                String   @id @default(cuid())
  sellerId          String
  categoryId        String
  commissionPercent Float // 0.0ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Â¦ÃƒÂ¢Ã¢â€šÂ¬Ã…â€œ100.0
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([sellerId, categoryId])
}

model SellerProductCommission {
  id                String   @id @default(cuid())
  sellerId          String
  productId         String
  commissionPercent Float
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([sellerId, productId])
}

// Per-order seller dispatch flag ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â controls when full buyer info appears in
// the seller portal (privacy: hidden until admin marks ready_to_dispatch).
model SellerOrderRelease {
  id               String    @id @default(cuid())
  orderId          String
  sellerId         String
  productIds       String[] // products of this seller in the order
  releasedAt       DateTime? // when admin marked "ready to dispatch"
  releasedByUserId String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([orderId, sellerId])

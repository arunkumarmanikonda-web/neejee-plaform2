¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚ÂÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚ÂÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚ÂÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚ÂÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚ÂÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚ÂÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚ÂÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚ÂÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬

// Vendor-raised AI photo request ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â the vendor uploads raw phone shots and asks
// admin to process them. Admin can accept (creating an AiPhotoJob) or reject.
model AiPhotoRequest {
  id                String               @id @default(cuid())
  vendorId          String
  vendor            Vendor               @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  // Target product (optional ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â vendor may request photos for a not-yet-listed product)
  productId         String?
  product           Product?             @relation(fields: [productId], references: [id], onDelete: SetNull)
  // Free-text description (what the product is, any styling notes, deadlines)
  description       String
  proposedCategory  String? // vendor's hint at category if no product linked
  // Raw phone shots
  sourceImageUrls   String[]             @default([])
  // Status
  status            AiPhotoRequestStatus @default(SUBMITTED)
  // When admin accepts, we link the resulting AiPhotoJob here
  resultingJobId    String?
  // Admin notes
  adminNote         String?
  reviewedByUserId  String?
  reviewedAt        DateTime?
  // Audit
  requestedByUserId String // the vendor user
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@index([vendorId, status])
  @@index([status, createdAt])
}

enum AiPhotoRequestStatus {
  SUBMITTED // vendor submitted, in admin queue
  ACCEPTED // admin accepted; AiPhotoJob created
  REJECTED // admin rejected with note
  COMPLETED // job done, vendor can view variants
  CANCELLED // vendor withdrew
}

// ============ JOURNAL AUTO-CURATION (v23.30) ============

model JournalDraft {
  id               String             @id @default(cuid())
  title            String
  excerpt          String?
  body             String             @db.Text
  coverImage       String?
  coverImagePrompt String?            @db.Text
  tags             String[]           @default([])
  seedTheme        String?
  seedRef          String?
  status           JournalDraftStatus @default(PENDING_REVIEW)
  approvalToken    String?            @unique
  reviewerNote     String?
  reviewedByUserId String?
  reviewedAt       DateTime?
  publishedPageId  String?
  createdByCron    Boolean            @default(false)
  storyImages      Json?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([status])
  @@index([createdAt(sort: Desc)])
}

enum JournalDraftStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
  PUBLISHED
}

model JournalSeedLog {
  id      String   @id @default(cuid())
  theme   String
  seedRef String?
  usedAt  DateTime @default(now())
  draftId String?

  @@index([usedAt(sort: Desc)])
}

model EditorialBlock {
  id           String               @id @default(cuid())
  slug         String               @unique
  title        String
  blockType    String
  body         String               @db.Text
  subhead      String?
  kicker       String?
  audienceTag  String?
  ctaLabel     String?
  ctaHref      String?
  coverImage   String?
  tags         String[]             @default([])
  placement    String?
  status       EditorialBlockStatus @default(DRAFT)
  previewToken String?              @unique
  publishedAt  DateTime?
  createdById  String?
  updatedById  String?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@index([status, updatedAt(sort: Desc)])
  @@index([placement])
  @@index([audienceTag])
}

enum EditorialBlockStatus {
  DRAFT
  PREVIEW
  PUBLISHED
  ARCHIVED
}

enum ErpQueueEntityType {
  PRODUCT
  INVENTORY
  PRICE
  SELLER
  ORDER
  PURCHASE_ORDER
}

enum ErpSyncAttemptStatus {
  QUEUED
  PROCESSING
  SUCCEEDED
  FAILED
  DEAD_LETTER
}

enum ErpDeadLetterStatus {
  OPEN
  RETRY_SCHEDULED
  RESOLVED
  DISCARDED
}

model ErpSyncAttempt {
  id             String               @id @default(cuid())
  entityType     ErpQueueEntityType
  entityKey      String
  adapterKind    String
  action         String
  status         ErpSyncAttemptStatus @default(QUEUED)
  attemptNumber  Int                  @default(1)
  maxAttempts    Int                  @default(5)
  runAfter       DateTime
  startedAt      DateTime?
  finishedAt     DateTime?
  errorCode      String?
  errorMessage   String?
  requestPayload Json?
  meta           Json?
  deadLetter     ErpDeadLetter?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([status, runAfter])
  @@index([entityType, entityKey])
  @@index([createdAt(sort: Desc)])
}

model ErpDeadLetter {
  id             String              @id @default(cuid())
  syncAttemptId  String              @unique
  syncAttempt    ErpSyncAttempt      @relation(fields: [syncAttemptId], references: [id], onDelete: Cascade)
  entityType     ErpQueueEntityType
  entityKey      String
  status         ErpDeadLetterStatus @default(OPEN)
  errorCode      String?
  errorMessage   String
  resolutionNote String?
  lastFailedAt   DateTime
  resolvedAt     DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([status, updatedAt(sort: Desc)])
  @@index([entityType, entityKey])
  @@index([lastFailedAt(sort: Desc)])
}

// ============ SHIPPING CONFIG (v23.32) ============
// Configurable shipping costs by zone (state / city / pincode pattern).
// Admins manage in /admin/settings/shipping. Resolver picks the best match
// at checkout based on the customer's destination pincode + state.

model ShippingZone {
  id                     String   @id @default(cuid())
  name                   String // e.g. "Hyderabad metro", "Tier 2 cities", "Rest of India"
  // Match rules - any match wins (most specific first via priority).
  pincodePrefixes        String[] @default([]) // e.g. ["500", "501"] matches all Hyderabad pincodes
  pincodeExact           String[] @default([]) // exact pincode whitelist
  states                 String[] @default([]) // e.g. ["Telangana", "Andhra Pradesh"]
  isDefault              Boolean  @default(false) // catch-all when no other zone matches
  // Cost (rounded to nearest 50 paise in the admin UI ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â stored in paise)
  standardPaise          Int      @default(15000)
  expressPaise           Int      @default(25000)
  freeAboveSubtotalPaise Int      @default(250000) // free when cart subtotal >= this
  // Inclusive mode: when true the shipping cost is absorbed into the product price
  // (customer sees ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Â¦Ãƒâ€šÃ‚Â¡ÃƒÆ’Ã†â€™ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¹0 shipping at checkout; admin reconciles internally).
  // When false the cost is added on top of the cart as a visible line item.
  inclusive              Boolean  @default(false)
  // Priority: higher = checked first. Default zones should have priority 0.
  priority               Int      @default(100)
  active                 Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([active, priority(sort: Desc)])
  @@index([isDefault])
}

// ============ CRAFTS (v23.33) ============
// First-class craft taxonomy. Until now `craft` was a free-text string on
// Product. Crafts are now a managed entity so admins can curate the list,
// add region context, SEO, hero imagery, and toggle visibility.
// Product.craft (string) stays in place for backwards compatibility ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â we
// optionally link via slug.

model Craft {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  region      String? // e.g. "Varanasi", "Bhuj"
  state       String? // e.g. "Uttar Pradesh"
  description String?  @db.Text
  longStory   String?  @db.Text // longer narrative shown on /crafts/[slug]
  image       String? // hero image URL
  thumbnail   String? // small image for cards
  seoTitle    String?
  seoDesc     String?
  featured    Boolean  @default(false) // shown on homepage rail
  active      Boolean  @default(true)
  order       Int      @default(0) // display order
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([active, order])
  @@index([featured])
}


}

model Payout {
  id                String       @id @default(cuid())
  sellerId          String
  seller            Seller       @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  // Period covered
  periodStart       DateTime
  periodEnd         DateTime
  // Money (all in paise)
  grossSales        Int          @default(0) // sum of seller's product sales in this period
  commissionPaise   Int          @default(0) // NEEJEE's cut
  netPayoutPaise    Int          @default(0) // what we owe the seller
  orderCount        Int          @default(0)
  // Status
  status            PayoutStatus @default(PENDING)
  utr               String? // bank transfer reference once paid
  paidAt            DateTime?
  notes             String?
  // v23.34 ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â RazorpayX integration
  rzpxPayoutId      String? // "pout_xxxxxxxxxxxxxx" ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â set after initiate
  rzpxStatus        String? // raw razorpay status snapshot
  rzpxFailReason    String? // captured on failure / reversal
  initiatedByUserId String?
  initiatedAt       DateTime?
  createdAt         DateTime     @default(now())

  @@index([sellerId, status])
  @@index([rzpxPayoutId])
}

enum PayoutStatus {
  PENDING
  PROCESSING
  PAID
  ON_HOLD
}

enum KycStatus {

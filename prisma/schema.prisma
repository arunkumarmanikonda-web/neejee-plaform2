// Vendor team members ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â accountant, dispatch person, etc.
// Each team member is a User row with role=VENDOR_STAFF and a link back to the
// parent Vendor via this table. Different team members can have different
// access levels (FULL, FINANCE_ONLY, OPERATIONS_ONLY).
model VendorTeamMember {
  id              String                @id @default(cuid())
  vendorId        String
  vendor          Vendor                @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  userId          String                @unique
  user            User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName     String?
  email           String // mirror for fast lookup
  accessLevel     VendorTeamAccessLevel @default(FULL)
  status          VendorTeamStatus      @default(INVITED)
  invitedByUserId String?
  invitedAt       DateTime              @default(now())
  acceptedAt      DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@index([vendorId])
  @@index([email])
}

enum VendorTeamAccessLevel {
  FULL // everything except sensitive bank/legal edits (still admin-approved)
  FINANCE_ONLY // payouts, TDS, invoices ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â no PO confirmation
  OPERATIONS_ONLY // PO confirm/dispatch, GRN, documents ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â no banking
}

enum VendorTeamStatus {
  INVITED
  ACTIVE
  SUSPENDED
  REMOVED
}

// Per-channel notification preferences. Vendor user (owner OR team member)
// chooses email/whatsapp/sms on/off. Events are not individually granular yet
// (per locked spec); a single toggle per channel covers all transactional updates.
model VendorNotificationPref {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailOptIn    Boolean  @default(true)
  whatsappOptIn Boolean  @default(true)
  smsOptIn      Boolean  @default(false) // SMS opt-in is more conservative
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Payout records ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â written when NEEJEE actually wires money to a vendor.
// For now this is admin-manual; Razorpay payouts will populate automatically
// once that integration ships.
model VendorPayout {
  id                String             @id @default(cuid())
  vendorId          String
  vendor            Vendor             @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  // What's being paid (one payout can cover multiple POs)
  poIds             String[] // array of PurchaseOrder ids covered by this payout
  // Amounts (paise)
  grossPaise        Int // sum of PO totals being settled
  tdsPaise          Int                @default(0) // TDS withheld
  netPaise          Int // grossPaise - tdsPaise (actually wired)
  // Payment details
  status            VendorPayoutStatus @default(SCHEDULED)
  paymentMethod     String? // "BANK_TRANSFER", "UPI", "RAZORPAY_PAYOUT"
  transactionRef    String? // UTR / Razorpay payout id
  scheduledFor      DateTime?
  paidAt            DateTime?
  failureReason     String?
  // Audit
  createdByUserId   String?
  notes             String?
  // v23.34 ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â RazorpayX integration
  rzpxPayoutId      String? // "pout_xxxxxxxxxxxxxx"
  rzpxStatus        String?
  rzpxFailReason    String?
  initiatedByUserId String?
  initiatedAt       DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([vendorId, status])
  @@index([status, scheduledFor])
  @@index([rzpxPayoutId])
}

enum VendorPayoutStatus {
  SCHEDULED // queued, not yet paid
  PROCESSING // sent to bank/Razorpay, awaiting confirmation
  PAID // confirmed
  FAILED // bounced
  CANCELLED
}


model SmsTemplate {
  id         String    @id @default(cuid())
  event      String    @unique // 'otp_login', 'order_placed', 'order_shipped', etc.
  label      String // human-friendly name shown in admin
  templateId String // 19-digit DLT message_id from operator portal
  body       String // approved message body with {#var#} placeholders
  varOrder   String[] // ordered variable keys e.g. ['otp'] or ['orderNumber','total']
  category   String    @default("transactional") // transactional | service_implicit | service_explicit
  active     Boolean   @default(true)
  notes      String?
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([event, active])
}

model OtpCode {
  id          String    @id @default(cuid())
  phone       String // E.164 format e.g. +919876543210
  codeHash    String // bcrypt hash of 6-digit code
  purpose     String // 'login_customer' | 'login_seller' | 'login_vendor' | 'admin_2fa' | 'checkout_guest'
  attempts    Int       @default(0)
  maxAttempts Int       @default(3)
  expiresAt   DateTime
  consumedAt  DateTime?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime  @default(now())

  @@index([phone, purpose, consumedAt])

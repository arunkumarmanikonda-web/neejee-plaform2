// Each expense entry references one category. Categories drive P&L grouping
// and the maker-checker approval threshold.
model ExpenseCategory {
  id                     String            @id @default(cuid())
  code                   String            @unique // 'MARKETING_META_ADS', 'COMMS_SMS', etc.
  label                  String // 'Meta Ads', 'SMS (Fast2SMS)'
  group                  ExpenseGroup
  parentCategoryId       String? // optional hierarchy (Marketing > Meta Ads)
  parentCategory         ExpenseCategory?  @relation("CategoryHierarchy", fields: [parentCategoryId], references: [id])
  children               ExpenseCategory[] @relation("CategoryHierarchy")
  // Maker-checker: entries above this threshold need approval. null = always approve, 0 = always pending.
  approvalThresholdPaise Int?
  // For coupon attribution: when a coupon assigned to this category is used, attribute revenue here
  isMarketingChannel     Boolean           @default(false)
  // GST claimable on this category?
  gstInputClaimable      Boolean           @default(true)
  isActive               Boolean           @default(true)
  expenses               Expense[]
  bills                  Bill[]            @relation("BillCategory")
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt

  @@index([group, isActive])
}

enum ExpenseGroup {
  COGS_DIRECT // inbound shipping, packaging
  OPEX_MARKETING // ads, influencer, campaigns
  OPEX_COMMUNICATION // SMS, WhatsApp, email
  OPEX_SHIPPING // outbound courier, reverse shipping
  OPEX_PAYMENT // gateway fees
  OPEX_PLATFORM // hosting, SaaS subscriptions
  OPEX_PEOPLE // salaries, contractors
  OPEX_OFFICE // rent, utilities
  OPEX_PROFESSIONAL // CA, legal
  OPEX_TAX_OTHER // misc taxes, fees
  OPEX_OTHER
  WRITE_OFF // damaged, lost
}

// Every cost entry. Manual OR auto-imported (Razorpay webhook, SMS provider, etc.)
model Expense {
  id                 String           @id @default(cuid())
  categoryId         String
  category           ExpenseCategory  @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  description        String
  amountPaise        Int // gross amount (excl GST)
  gstPaise           Int              @default(0) // GST input we can claim
  totalPaise         Int // amountPaise + gstPaise
  // Dates: incurred = when the cost happened (accrual); paidAt = when we paid (cash)
  incurredOn         DateTime // service-date
  paidOn             DateTime? // when we actually paid (null if unpaid bill)
  // Counterparty
  vendorId           String? // Vendor model (inventory supplier)
  vendorNameSnapshot String? // for non-Vendor counterparties
  invoiceNumber      String?
  receiptUrl         String?
  attachments        String[]         @default([]) // v23.39.4 ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â multiple supporting files (images/PDF/Excel/CSV)
  // v23.40.2 ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â payment tracking against booked expense (running total of ExpensePayment.amountPaise)
  paidPaise          Int              @default(0)
  paymentStatus      String           @default("UNPAID") // 'UNPAID' | 'PARTIALLY_PAID' | 'PAID'
  // Maker-checker workflow
  status             ExpenseStatus    @default(DRAFT)
  createdByUserId    String
  reviewedByUserId   String?
  reviewedAt         DateTime?
  reviewNote         String?
  // Auto-ingestion
  source             ExpenseSource    @default(MANUAL)
  sourceRef          String? // e.g. Razorpay payment id, Fast2SMS bill id
  // Order linkage (for per-order fees like Razorpay)
  orderId            String?
  notes              String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  // v23.40.2 ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â payments against this expense
  payments           ExpensePayment[]

  @@index([categoryId, incurredOn])
  @@index([status, createdAt])
  @@index([source, sourceRef])
  @@index([incurredOn])
  @@index([paidOn])
  @@index([orderId])
}

enum ExpenseStatus {
  DRAFT // created by FINANCE_OPERATOR, not yet submitted
  PENDING // submitted, awaiting approval
  APPROVED // approved & live in reports
  REJECTED // bounced back
  VOIDED // cancelled after approval (for corrections)
}

enum ExpenseSource {
  MANUAL
  BILL // v23.40.10 ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â auto-created mirror of a Bill (P&L hit)
  RAZORPAY_WEBHOOK
  FAST2SMS_AUTO
  RESEND_AUTO
  SHIPROCKET_AUTO
  IMPORT
}


// Models for tracking bank accounts, raw transactions, and reconciliation matches.

model BankAccount {
  id                  String            @id @default(cuid())
  // Identification
  nickname            String // "HDFC Current ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â Main", "RazorpayX Virtual"
  bankName            String // 'HDFC', 'ICICI', 'RAZORPAYX', 'SBI'
  accountNumber       String? // last 4 digits or masked
  ifsc                String?
  accountType         String? // 'CURRENT' | 'SAVINGS' | 'VIRTUAL'
  // Operational
  active              Boolean           @default(true)
  // Currency
  currency            String            @default("INR")
  // Opening balance (paise) ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â set once, used as anchor
  openingBalancePaise Int               @default(0)
  openingBalanceDate  DateTime?
  // Sync metadata
  lastSyncedAt        DateTime?
  lastSyncedSource    String? // 'CSV' | 'RAZORPAYX_API' | 'MANUAL'
  // For RazorpayX
  rzpxAccountId       String? // e.g. "acc_xxx" if RazorpayX
  // Audit
  createdByUserId     String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  transactions        BankTransaction[]

  @@index([active, bankName])
}

model BankTransaction {
  id                   String        @id @default(cuid())
  bankAccountId        String
  bankAccount          BankAccount   @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  // The transaction itself
  txnDate              DateTime // value date / posted date
  description          String // bank narration as-is
  reference            String? // UTR / cheque number / chq ref
  // Money (paise) ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â exactly one of debit/credit is non-zero
  debitPaise           Int           @default(0) // money out
  creditPaise          Int           @default(0) // money in
  balancePaise         Int? // closing balance from statement if available
  // Source
  source               String // 'CSV_HDFC' | 'CSV_GENERIC' | 'RAZORPAYX_API' | 'MANUAL'
  sourceFileUrl        String? // link to the CSV upload that originated this row
  sourceRowHash        String? // hash of raw row to detect duplicates on re-upload
  // Reconciliation status
  status               BankTxnStatus @default(UNMATCHED)
  matchedExpenseId     String? // when matched to an Expense row
  matchedBillPaymentId String? // when matched to a BillPayment
  matchedRefundId      String? // when matched to a refund / customer payment
  matchNotes           String?
  matchedAt            DateTime?
  matchedByUserId      String?
  // Audit
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  @@index([bankAccountId, txnDate])
  @@index([status])
  @@index([sourceRowHash])
  @@index([reference])
}

enum BankTxnStatus {
  UNMATCHED // freshly imported, no link
  AUTO_MATCHED // engine matched with high confidence
  MANUAL_MATCHED // user confirmed
  IGNORED // user marked as not relevant (e.g. internal transfer)

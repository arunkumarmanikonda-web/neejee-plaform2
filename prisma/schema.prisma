// Logs every CREATE/UPDATE/DELETE on financial records with field-level diff.
// Heavy but bulletproof ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â required for SOC2-style compliance and forensic audits.
model FinanceAuditLog {
  id           String   @id @default(cuid())
  // What happened
  action       String // 'CREATE' | 'UPDATE' | 'DELETE'
  entityType   String // 'Bill' | 'BillPayment' | 'Expense' | 'Employee' | 'Payslip' | ...
  entityId     String // primary key of the affected row
  // Field-level diff (for UPDATE). JSON-serialized.
  changesJson  String? // { fieldName: { from: X, to: Y }, ... }
  fullSnapshot String? // optional full row JSON at the time of change (for CREATE/DELETE)
  // Who & when
  userId       String? // null if system/cron initiated
  userEmail    String? // captured at write-time so logs survive user deletion
  userRole     String?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())

  @@index([entityType, entityId])
  @@index([userId, createdAt])

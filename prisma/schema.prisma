// Every return / partial return logged here. Drives the "Returns" P&L line
// and lets us write back COGS for restocked items.
model ReturnEntry {
  id                   String    @id @default(cuid())
  orderId              String // the original order
  orderNumber          String // snapshot
  // Customer & timing
  returnedOn           DateTime // when goods came back
  refundedOn           DateTime?
  // Money flow (paise)
  refundedAmountPaise  Int // what we paid the customer
  reverseShippingPaise Int       @default(0)
  damagedValuePaise    Int       @default(0) // write-off
  restockedValuePaise  Int       @default(0) // COGS write-back
  // Disposition per line (JSON of {orderItemId, qtyReturned, qtyRestocked, qtyDamaged})
  lineBreakdown        Json
  reason               String?
  notes                String?
  createdByUserId      String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([returnedOn])

// Uploaded files. Vendors upload directly; admins can upload on their behalf
// (e.g. when a less tech-literate vendor sends docs via WhatsApp). Files are
// stored in Supabase Storage under `vendor-docs/<vendorId>/`.
model VendorDocument {
  id               String               @id @default(cuid())
  vendorId         String
  vendor           Vendor               @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  docType          VendorDocType
  // Display name (e.g. "PAN Card") and original filename
  title            String?
  fileName         String
  fileUrl          String // Supabase public URL
  fileSize         Int // bytes
  mimeType         String
  status           VendorDocStatus      @default(SUBMITTED)
  // Audit
  uploadedByUserId String // who actually clicked upload (vendor user OR admin)
  uploadedOnBehalf Boolean              @default(false) // true if admin uploaded for vendor
  reviewedByUserId String?
  reviewedAt       DateTime?
  reviewNote       String?
  // Link to a change request if this doc supports one (e.g. cancelled cheque for bank update)
  changeRequestId  String?
  changeRequest    VendorChangeRequest? @relation(fields: [changeRequestId], references: [id], onDelete: SetNull)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@index([vendorId, docType])
  @@index([status])
  @@index([changeRequestId])
}

enum VendorDocType {
  PAN_CARD
  GST_CERTIFICATE
  MSME_CERTIFICATE
  CANCELLED_CHEQUE
  BANK_STATEMENT
  ADDRESS_PROOF
  AADHAAR_SIGNATORY
  SIGNATORY_PHOTO
  VENDOR_AGREEMENT
  INVOICE
  GRN_DISPUTE
  OTHER
}

enum VendorDocStatus {
  SUBMITTED // uploaded, awaiting review
  APPROVED // verified by admin
  REJECTED // bounced ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â vendor must re-upload
  SUPERSEDED // a newer version exists
}

// A request to change a sensitive field. The vendor (or admin on their behalf)
// creates the request; the field doesn't actually update on Vendor until an
// ADMIN/SUPER_ADMIN/FINANCE user APPROVES it. Each request must reference at
// least one supporting document (enforced at API level).
model VendorChangeRequest {
  id                String                    @id @default(cuid())
  vendorId          String
  vendor            Vendor                    @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  // What changed
  fieldChanges      Json // [{field, oldValue, newValue}]
  reason            String? // vendor-provided reason (optional)
  status            VendorChangeRequestStatus @default(PENDING)
  // Audit
  requestedByUserId String // vendor user OR admin if filed on behalf
  requestedOnBehalf Boolean                   @default(false)
  reviewedByUserId  String?
  reviewedAt        DateTime?
  reviewNote        String?
  appliedAt         DateTime? // when changes actually wrote to Vendor
  cancelledAt       DateTime? // vendor cancelled before review
  // Supporting documents
  supportingDocs    VendorDocument[]
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt

  @@index([vendorId, status])
  @@index([status, createdAt])
}

enum VendorChangeRequestStatus {
  PENDING // waiting for admin review
  APPROVED // approved, fields applied to Vendor
  REJECTED // declined, no changes applied
  CANCELLED // vendor withdrew before review
}

// Append-only audit log of vendor-related actions. Useful for compliance.
model VendorAuditLog {
  id          String   @id @default(cuid())
  vendorId    String
  vendor      Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  actorUserId String? // null = system event
  actorRole   String? // VENDOR, ADMIN, SUPER_ADMIN, FINANCE, SYSTEM
  action      String // LOGIN, PROFILE_EDIT, CHANGE_REQUESTED, CHANGE_APPROVED, etc.
  details     Json?
  ipAddress   String?
  createdAt   DateTime @default(now())

  @@index([vendorId, createdAt])
  @@index([action, createdAt])
}


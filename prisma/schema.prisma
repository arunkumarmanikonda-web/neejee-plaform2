// Designed for 50+ employees, monthly batch runs, statutory deductions toggleable.

model Employee {
  id                  String                     @id @default(cuid())
  // Identification
  employeeCode        String                     @unique // EMP001, EMP002, ...
  firstName           String
  lastName            String?
  email               String?                    @unique
  phone               String?
  // Optional link to a User account
  userId              String?                    @unique
  // KYC
  pan                 String?                    @unique // ABCDE1234F
  aadhaarLast4        String? // last 4 digits only (privacy)
  dob                 DateTime?
  // Employment
  designation         String? // "Operations Lead"
  department          String? // "Operations", "Marketing"
  joiningDate         DateTime
  exitDate            DateTime?
  employmentType      String                     @default("FULL_TIME") // FULL_TIME | PART_TIME | CONTRACT | INTERN
  status              EmployeeStatus             @default(ACTIVE)
  // v23.40.1 ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â Exit / resignation tracking
  resignationDate     DateTime? // date the employee submitted resignation
  noticePeriodDays    Int?                       @default(30) // contractual notice period
  lastWorkingDay      DateTime? // actual LWD (may differ from exitDate after F&F)
  exitReason          String? // "resigned" | "terminated" | "absconded" | "retired" | "layoff"
  exitType            String? // "VOLUNTARY" | "INVOLUNTARY" | "RETIREMENT"
  exitNotes           String? // free-form HR notes / handover summary
  // v23.40.1 ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â Personal-file documents (PAN copy, Aadhaar, cancelled cheque, photo, offer letter, etc.)
  documents           String[]                   @default([]) // array of file URLs
  photoUrl            String? // primary profile photo
  // Bank for salary credit
  bankAccountName     String?
  bankAccountNumber   String?
  bankIfsc            String?
  // Statutory IDs (only used if respective deduction is enabled)
  uanNumber           String? // PF Universal Account Number
  esicNumber          String? // ESIC Insured Number
  // Tax regime preference (Section 192)
  taxRegime           String                     @default("NEW") // 'OLD' | 'NEW'
  // Notes & metadata
  address             String?
  emergencyContact    String?
  notes               String?
  // Audit
  createdByUserId     String?
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt
  // Relations
  salaryAssignments   EmployeeSalaryAssignment[]
  attendance          Attendance[]
  payslips            Payslip[]
  adjustments         EmployeeAdjustment[]
  // v23.40.1
  reimbursementPolicy ReimbursementPolicy?
  incentivePlan       IncentivePlan?
  fnfSettlements      FnFSettlement[]

  @@index([status])
  @@index([department, status])
}

// v23.40.1 ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â Reimbursement caps that flow into monthly payroll as auto-earnings.
// One record per employee (1:1). Caps are monthly ceilings; actual claims still recorded as adjustments.
model ReimbursementPolicy {
  id                 String   @id @default(cuid())
  employeeId         String   @unique
  employee           Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  // Monthly caps (paise)
  mobileCapPaise     Int      @default(0) // mobile / telecom
  conveyanceCapPaise Int      @default(0) // conveyance / fuel
  internetCapPaise   Int      @default(0) // home internet
  foodCapPaise       Int      @default(0) // meal allowance
  fuelCapPaise       Int      @default(0) // separate fuel allowance
  bookCapPaise       Int      @default(0) // books & periodicals
  otherCapPaise      Int      @default(0) // generic / custom
  // Auto-add to monthly payroll? (false = employee must claim via adjustment)
  autoAddToPayroll   Boolean  @default(true)
  notes              String?
  updatedAt          DateTime @updatedAt
}

// v23.40.1 ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â Performance pay / incentive plan per employee.
model IncentivePlan {
  id                  String   @id @default(cuid())
  employeeId          String   @unique
  employee            Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  // Plan type
  planType            String   @default("FIXED") // 'FIXED' | 'PERCENT_OF_TARGET' | 'SLAB' | 'CUSTOM'
  // Fixed monthly incentive (paise)
  fixedIncentivePaise Int      @default(0)
  // Variable: % of target achievement applied to a base
  variableBasePaise   Int      @default(0) // base amount payable at 100% achievement
  variableMaxPaise    Int      @default(0) // cap
  // Bonus structures
  quarterlyBonusPaise Int      @default(0) // accrued each quarter
  annualBonusPaise    Int      @default(0) // accrued / paid annually (Diwali, year-end)
  // Frequency: when does it pay out
  payoutFrequency     String   @default("MONTHLY") // 'MONTHLY' | 'QUARTERLY' | 'ANNUALLY' | 'EVENT'
  // Optional: target metric for tracking (descriptive)
  metric              String? // "Monthly sales", "Orders shipped", "NPS score"
  notes               String?
  active              Boolean  @default(true)
  updatedAt           DateTime @updatedAt
}

// v23.40.1 ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â Full & Final settlement.
// Generated when an employee exits.  One row per settlement (usually one per employee).
model FnFSettlement {
  id                    String    @id @default(cuid())
  employeeId            String
  employee              Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  // Exit context
  resignationDate       DateTime?
  lastWorkingDay        DateTime
  noticePeriodDays      Int       @default(30)
  noticeShortfallDays   Int       @default(0) // days short of notice  ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â recovered from F&F
  exitReason            String?
  // Pending salary for the final partial month
  pendingSalaryPaise    Int       @default(0) // pro-rata current month
  pendingDaysWorked     Int       @default(0)
  // Leave encashment
  leaveBalanceDays      Float     @default(0)
  leaveEncashmentPaise  Int       @default(0)
  // Bonus / incentive arrears
  bonusDuePaise         Int       @default(0)
  incentiveDuePaise     Int       @default(0)
  reimbursementDuePaise Int       @default(0)
  // Gratuity (Payment of Gratuity Act ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â 5y+ tenure)
  gratuityPaise         Int       @default(0)
  gratuityEligible      Boolean   @default(false)
  // Recoveries
  noticeRecoveryPaise   Int       @default(0) // recovery for shortfall in notice
  loanRecoveryPaise     Int       @default(0)
  advanceRecoveryPaise  Int       @default(0)
  otherRecoveryPaise    Int       @default(0)
  // Statutory deductions on final amount
  tdsPaise              Int       @default(0)
  pfFinalPaise          Int       @default(0)
  esiFinalPaise         Int       @default(0)
  // Totals (computed)
  totalEarningsPaise    Int       @default(0)
  totalDeductionsPaise  Int       @default(0)
  netPayablePaise       Int       @default(0) // can be negative (employee owes company)
  // Lifecycle
  status                String    @default("DRAFT") // 'DRAFT' | 'APPROVED' | 'PAID' | 'CANCELLED'
  approvedByUserId      String?
  approvedAt            DateTime?
  paidOn                DateTime?
  paymentReference      String?
  // Supporting documents (handover, no-dues, etc.)
  attachments           String[]  @default([])
  notes                 String?
  // Audit
  createdByUserId       String
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([employeeId])
  @@index([status])
}

enum EmployeeStatus {
  ACTIVE
  ON_NOTICE
  EXITED
  ON_LEAVE
  TERMINATED
}

// A reusable salary structure (template).
// Each employee can have multiple structures over time (assignments).
model SalaryStructure {
  id                    String                     @id @default(cuid())
  name                  String // "Standard Operations Tier 1"
  description           String?
  // Monthly CTC components (paise)
  basicPaise            Int // typically 40-50% of CTC
  hraPaise              Int // typically 40-50% of basic
  conveyancePaise       Int                        @default(0)
  medicalPaise          Int                        @default(0)
  specialAllowancePaise Int                        @default(0) // balancing figure
  // Optional flat allowances
  ltaMonthlyPaise       Int                        @default(0) // Leave Travel
  performanceBonusPaise Int                        @default(0) // baseline; actuals come from adjustments
  // Derived
  monthlyCtcPaise       Int // sum of above (for display only)
  // Lifecycle
  active                Boolean                    @default(true)
  createdByUserId       String?
  createdAt             DateTime                   @default(now())
  updatedAt             DateTime                   @updatedAt
  assignments           EmployeeSalaryAssignment[]

  @@index([active])
}

model EmployeeSalaryAssignment {
  id               String          @id @default(cuid())
  employeeId       String
  employee         Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  structureId      String
  structure        SalaryStructure @relation(fields: [structureId], references: [id], onDelete: Restrict)
  effectiveFrom    DateTime // first month this assignment applies
  effectiveTo      DateTime? // null = current
  // Override fields (optional ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â if set, override structure values for this employee)
  ctcOverridePaise Int? // total monthly CTC override
  notes            String?
  createdByUserId  String?
  createdAt        DateTime        @default(now())

  @@index([employeeId, effectiveFrom])
  @@index([effectiveTo])
}

// Monthly payroll run ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â one row per (month, year).
model PayrollRun {
  id                   String           @id @default(cuid())
  month                Int // 1-12
  year                 Int // e.g. 2026
  label                String // "June 2026"
  status               PayrollRunStatus @default(DRAFT)
  // Computed totals (paise) ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â for dashboard cards
  totalGrossPaise      Int              @default(0)
  totalDeductionsPaise Int              @default(0)
  totalNetPaise        Int              @default(0)
  employeeCount        Int              @default(0)
  // Workflow timestamps
  computedAt           DateTime?
  approvedAt           DateTime?
  approvedByUserId     String?
  paidAt               DateTime?
  paidByUserId         String?
  notes                String?
  createdByUserId      String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  payslips             Payslip[]

  @@unique([month, year])
  @@index([status, year, month])
}

enum PayrollRunStatus {
  DRAFT // created, not computed yet
  COMPUTED // amounts calculated, awaiting approval
  APPROVED // sign-off, ready to pay
  PAID // disbursed (creates Bills/Expenses)
  LOCKED // year-end close ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â no edits
}

// Per-employee payroll line for a given run.
model Payslip {
  id                    String     @id @default(cuid())
  payrollRunId          String
  payrollRun            PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  employeeId            String
  employee              Employee   @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  // Attendance proration
  daysInMonth           Int // calendar days in month
  daysWorked            Int // actual days worked
  leavesPaid            Int        @default(0)
  leavesUnpaid          Int        @default(0)
  // Earnings (paise)
  basicPaise            Int        @default(0)
  hraPaise              Int        @default(0)
  conveyancePaise       Int        @default(0)
  medicalPaise          Int        @default(0)
  specialAllowancePaise Int        @default(0)
  ltaPaise              Int        @default(0)
  bonusPaise            Int        @default(0)
  incentivePaise        Int        @default(0) // from adjustments
  reimbursementPaise    Int        @default(0)
  otherEarningsPaise    Int        @default(0)
  grossPaise            Int        @default(0) // sum of earnings
  // Statutory deductions (paise) ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â zero if disabled
  pfEmployeePaise       Int        @default(0)
  pfEmployerPaise       Int        @default(0) // shown for ref; doesn't reduce net
  esiEmployeePaise      Int        @default(0)
  esiEmployerPaise      Int        @default(0) // shown for ref
  tdsPaise              Int        @default(0)
  professionalTaxPaise  Int        @default(0)
  // Other deductions
  advanceRecoveryPaise  Int        @default(0)
  loanRepaymentPaise    Int        @default(0)
  finesPaise            Int        @default(0)
  otherDeductionsPaise  Int        @default(0)
  totalDeductionsPaise  Int        @default(0)
  // Net pay
  netPaise              Int        @default(0)
  // Disbursement
  paidOn                DateTime?
  paymentMethod         String? // BANK_TRANSFER, UPI, CASH
  paymentReference      String?
  payslipUrl            String? // PDF URL once generated
  // Delivery
  deliveredEmailAt      DateTime?
  deliveredWhatsappAt   DateTime?
  deliveredSmsAt        DateTime?
  // Notes
  notes                 String?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  @@unique([payrollRunId, employeeId])
  @@index([employeeId, payrollRunId])
}

// Monthly attendance ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â typically uploaded as CSV or set manually.
model Attendance {

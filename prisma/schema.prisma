// PoMessage ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â thread of messages between admin and vendor on a Purchase Order.
// Used for clarifications, dispatch updates, dispute escalation. Notifications
// fire to the other party via the existing notify() engine.
model PoMessage {
  id              String        @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  // Author identification
  authorUserId    String // who wrote it
  authorRole      String // 'ADMIN' | 'VENDOR' | 'VENDOR_STAFF' (snapshot for audit)
  authorName      String // display name snapshot
  // Content
  body            String // plain text, up to ~2000 chars
  attachments     String[]      @default([]) // optional file URLs (Supabase storage)
  // Read tracking (simple: vendor-side read timestamp + admin-side read timestamp)
  readByVendorAt  DateTime?
  readByAdminAt   DateTime?
  // Audit
  createdAt       DateTime      @default(now())

  @@index([purchaseOrderId, createdAt])
}

// Dispute ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â polymorphic raise-an-issue thread.
// Covers both ORDER (customer says "wrong item") and PURCHASE_ORDER (admin says
// "you shipped 80 of 100, where's the rest?"). One DisputeEvent per timeline
// update, plus an attachments array on the parent for evidence.
model Dispute {
  id                    String              @id @default(cuid())
  // Polymorphic target ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â exactly one of these is non-null
  resourceType          DisputeResourceType
  orderId               String?
  order                 Order?              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  purchaseOrderId       String?
  purchaseOrder         PurchaseOrder?      @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  // Counterparty (so vendor/seller portal queries are O(1))
  vendorId              String?
  sellerId              String?
  customerUserId        String?
  // Raised by
  raisedByUserId        String
  raisedByRole          String // 'CUSTOMER' | 'ADMIN' | 'VENDOR' | 'SELLER'
  // Category & lifecycle
  category              DisputeCategory
  severity              DisputeSeverity     @default(MEDIUM)
  status                DisputeStatus       @default(OPEN)
  title                 String // short summary
  description           String // initial complaint text
  evidenceUrls          String[]            @default([]) // photos, PDFs in storage
  // Resolution
  resolutionNote        String?
  resolutionAmountPaise Int? // refund/credit if any
  resolvedAt            DateTime?
  resolvedByUserId      String?
  // SLA tracking
  dueBy                 DateTime? // computed from severity at creation
  firstResponseAt       DateTime?
  // Audit
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  events                DisputeEvent[]

  @@index([resourceType, status])
  @@index([vendorId, status])
  @@index([sellerId, status])
  @@index([customerUserId, status])
  @@index([createdAt])
}

// DisputeEvent ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â one row per state change or message.
model DisputeEvent {
  id          String           @id @default(cuid())
  disputeId   String
  dispute     Dispute          @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  actorUserId String?
  actorRole   String? // 'ADMIN' | 'CUSTOMER' | 'VENDOR' | 'SELLER' | 'SYSTEM'
  type        DisputeEventType
  // Type-specific payload
  body        String? // message text (for COMMENT) or status reason
  fromStatus  DisputeStatus?
  toStatus    DisputeStatus?
  attachments String[]         @default([])
  createdAt   DateTime         @default(now())

  @@index([disputeId, createdAt])
}

enum DisputeResourceType {
  ORDER // customer ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â admin
  PURCHASE_ORDER // admin ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â vendor
}

enum DisputeCategory {
  WRONG_ITEM
  DAMAGED
  NOT_RECEIVED
  QUALITY_ISSUE
  SHORT_SHIPMENT
  LATE_DELIVERY
  PAYMENT_ISSUE
  OTHER
}

enum DisputeSeverity {
  LOW // SLA 7 days
  MEDIUM // SLA 3 days
  HIGH // SLA 1 day
  CRITICAL // SLA 4 hours
}

enum DisputeStatus {
  OPEN
  AWAITING_CUSTOMER // ball is in the customer's court (need photo etc.)
  AWAITING_VENDOR // ball is in the vendor's court
  UNDER_REVIEW // admin investigating
  RESOLVED // closed with resolution note + optional refund
  REJECTED // dismissed (no compensation)
  WITHDRAWN // raiser cancelled
}

enum DisputeEventType {
  CREATED
  COMMENT
  STATUS_CHANGED
  EVIDENCE_ADDED
  RESOLUTION_PROPOSED
  RESOLVED
}

// ForecastSnapshot ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â pre-computed demand forecast.
// Refreshed by a daily cron (Holt-Winters style additive seasonality, weekly).
// We snapshot to avoid recomputing on every page load.
model ForecastSnapshot {
  id                String        @id @default(cuid())
  scope             ForecastScope
  // When scope=PRODUCT, productId is set; scope=CATEGORY ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¾Ãƒâ€šÃ‚Â¢ categoryId; scope=GLOBAL ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¾Ãƒâ€šÃ‚Â¢ both null
  productId         String?
  categoryId        String?
  // Historical window the forecast was trained on
  windowStartDate   DateTime
  windowEndDate     DateTime
  // Forecast horizon (next N days)
  horizonDays       Int           @default(90)
  // Cached series: each entry { date, predicted, lower, upper }
  series            Json // [{date:'2026-06-15', predicted:42, lower:35, upper:50}, ...]
  // Diagnostics: { trend, seasonalIndices, rmse, mape, dataPoints }
  diagnostics       Json
  // Restock recommendation (computed from horizon + lead time)
  reorderHint       String? // e.g. "Restock by Jun 18 ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â at current velocity will stock out Jun 22"
  daysUntilStockout Int?
  // Audit
  createdAt         DateTime      @default(now())
  expiresAt         DateTime // typically createdAt + 24h

  @@unique([scope, productId, categoryId])
  @@index([scope, expiresAt])
}

enum ForecastScope {
  GLOBAL // platform-wide
  CATEGORY // per Category
  PRODUCT // per Product (most useful for stock-out warnings)
}


    "@radix-ui/react-tabs": "^1.1.15",
    "@sentry/nextjs": "^8.40.0",
    "@sparticuz/chromium": "^126.0.0",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "exceljs": "^4.4.0",
    "jose": "^5.9.0",
    "lucide-react": "^0.452.0",
    "nanoid": "^5.1.15",
    "next": "^14.2.0",
    "pdf-parse": "^1.1.4",
    "prisma": "^5.20.0",
    "puppeteer-core": "^25.3.0",
    "razorpay": "^2.9.0",
    "react": "^18.3.0",

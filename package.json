{
  "name": "neejee-platform",
  "version": "0.1.0",
  "private": true,
  "description": "NEEJEE — Found. Personal. Premium Indian craft ecommerce + marketplace + AI commerce.",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "test": "tsx --test __tests__/**/*.test.ts",
    "test:catalog": "tsx --test __tests__/catalog/*.test.ts",
    "postinstall": "prisma generate",
    "seed": "tsx scripts/seed.ts",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset --force && npm run seed"
  },
  "dependencies": {
    "@prisma/client": "^5.20.0",
    "@radix-ui/react-dialog": "^1.1.17",
